<div id="lightbox-overlay" class="fixed inset-0 z-[9999] bg-black/95 hidden items-center justify-center">
  <button id="lightbox-close" class="absolute top-6 right-6 z-10 w-12 h-12 bg-[#CD5C5C] flex items-center justify-center skew-block hover:brightness-110 transition-all" aria-label="Close lightbox">
    <span class="material-symbols-outlined text-white text-2xl skew-block-content">close</span>
  </button>
  <button id="lightbox-prev" class="absolute left-4 md:left-8 z-10 w-12 h-12 bg-white/10 flex items-center justify-center skew-block hover:bg-[#CD5C5C] transition-all" aria-label="Previous image">
    <span class="material-symbols-outlined text-white text-2xl skew-block-content">chevron_left</span>
  </button>
  <button id="lightbox-next" class="absolute right-4 md:right-8 z-10 w-12 h-12 bg-white/10 flex items-center justify-center skew-block hover:bg-[#CD5C5C] transition-all" aria-label="Next image">
    <span class="material-symbols-outlined text-white text-2xl skew-block-content">chevron_right</span>
  </button>
  <div class="max-w-6xl max-h-[85vh] mx-auto px-16 flex items-center justify-center">
    <img id="lightbox-img" class="max-w-full max-h-[80vh] object-contain" src="" alt="" />
  </div>
  <div id="lightbox-counter" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/60 font-['Space_Grotesk'] text-sm uppercase tracking-widest font-bold"></div>
  <div id="lightbox-caption" class="absolute bottom-12 left-1/2 -translate-x-1/2 text-white font-['Space_Grotesk'] text-sm uppercase tracking-wider font-bold"></div>
</div>

<script>
  const galleryData: Record<string, { src: string; alt: string; caption?: string }[]> = {};

  document.querySelectorAll('.gallery-item').forEach(item => {
    const galleryId = item.getAttribute('data-gallery');
    if (!galleryId) return;
    if (!galleryData[galleryId]) galleryData[galleryId] = [];

    const index = parseInt(item.getAttribute('data-index') || '0');
    const img = item.querySelector('img');
    if (img) {
      galleryData[galleryId][index] = {
        src: img.src,
        alt: img.alt,
        caption: img.parentElement?.querySelector('[class*="caption"]')?.textContent || undefined
      };
    }

    item.addEventListener('click', () => openLightbox(galleryId, index));
  });

  let currentGallery = '';
  let currentIndex = 0;

  function openLightbox(galleryId: string, index: number) {
    currentGallery = galleryId;
    currentIndex = index;
    updateLightbox();
    const overlay = document.getElementById('lightbox-overlay');
    if (overlay) {
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeLightbox() {
    const overlay = document.getElementById('lightbox-overlay');
    if (overlay) {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
      document.body.style.overflow = '';
    }
  }

  function updateLightbox() {
    const images = galleryData[currentGallery];
    if (!images || !images[currentIndex]) return;
    const { src, alt, caption } = images[currentIndex];
    const img = document.getElementById('lightbox-img');
    const counter = document.getElementById('lightbox-counter');
    const captionEl = document.getElementById('lightbox-caption');

    if (img) { img.src = src; img.alt = alt; }
    if (counter) counter.textContent = `${currentIndex + 1} / ${images.length}`;
    if (captionEl) captionEl.textContent = caption || '';
  }

  function navigateLightbox(direction: number) {
    const images = galleryData[currentGallery];
    if (!images) return;
    currentIndex = (currentIndex + direction + images.length) % images.length;
    updateLightbox();
  }

  document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
  document.getElementById('lightbox-prev')?.addEventListener('click', () => navigateLightbox(-1));
  document.getElementById('lightbox-next')?.addEventListener('click', () => navigateLightbox(1));

  document.getElementById('lightbox-overlay')?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).id === 'lightbox-overlay') closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (document.getElementById('lightbox-overlay')?.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') navigateLightbox(-1);
    if (e.key === 'ArrowRight') navigateLightbox(1);
  });

  function initScrollDriven() {
    const progressBar = document.querySelector('.hscroll-progress-bar') as HTMLElement;

    document.querySelectorAll('[data-hscroll]').forEach(proxy => {
      if (proxy.dataset.hscrollInit) return;
      proxy.dataset.hscrollInit = '1';

      const sticky = proxy.querySelector('.hscroll-sticky') as HTMLElement;
      const track = proxy.querySelector('.hscroll-track') as HTMLElement;
      if (!sticky || !track) return;

      let rafId = 0;

      function calcProxyHeight() {
        const trackWidth = track.scrollWidth;
        const viewportWidth = window.innerWidth;
        const stickyHeight = window.innerHeight;
        const extraScroll = Math.max(0, trackWidth - viewportWidth);
        proxy.style.height = (stickyHeight + extraScroll) + 'px';
      }

      function onScroll() {
        cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(() => {
          const proxyScrollable = proxy.offsetHeight - window.innerHeight;
          if (proxyScrollable <= 0) return;

          const scrolled = Math.max(0, Math.min(proxyScrollable, -proxy.getBoundingClientRect().top));
          const progress = scrolled / proxyScrollable;

          const maxTranslate = track.scrollWidth - (track.parentElement?.offsetWidth || window.innerWidth);
          track.style.transform = `translateX(${-progress * maxTranslate}px)`;

          if (progressBar) {
            const isVisible = progress > 0.001 && progress < 0.999;
            progressBar.style.opacity = isVisible ? '1' : '0';
            progressBar.style.width = `${progress * 100}%`;
          }
        });
      }

      calcProxyHeight();
      onScroll();

      window.addEventListener('scroll', onScroll, { passive: true });

      let resizeTimer: number;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => {
          calcProxyHeight();
          onScroll();
        }, 100);
      });

      new ResizeObserver(() => {
        calcProxyHeight();
        onScroll();
      }).observe(track);
    });
  }

  initScrollDriven();
</script>
