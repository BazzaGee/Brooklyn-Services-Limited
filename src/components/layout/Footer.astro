---
import AnimatedLogo from '../ui/AnimatedLogo.astro';

const expertiseLinks = [
  { label: 'Plumbing Systems', href: '/services/plumbing/' },
  { label: 'Drainage Logistics', href: '/services/drainage/' },
  { label: 'Acoustic Detection', href: '/services/leak-detection/' },
  { label: 'Utility Mapping', href: '/services/utility-locating/' },
];

const areaLinks = [
  { label: 'Christchurch', href: '/areas/christchurch/' },
  { label: 'Rolleston', href: '/areas/rolleston/' },
  { label: 'Lincoln', href: '/areas/lincoln/' },
  { label: 'Rangiora', href: '/areas/rangiora/' },
  { label: 'Kaiapoi', href: '/areas/kaiapoi/' },
  { label: 'Ashburton', href: '/areas/ashburton/' },
];

const resourceLinks = [
  { label: 'Blog & Resources', href: '/blog/' },
  { label: 'About Us', href: '/about/' },
  { label: 'Projects', href: '/projects/' },
];

const regulatoryLinks = [
  { label: 'Privacy Protocol', href: '/privacy/' },
  { label: 'Terms of Engagement', href: '/terms/' },
  { label: 'Safety Compliance', href: '/safety/' },
];
---

<footer class="w-full py-16 lg:py-24 px-6 lg:px-8 bg-[#1b1b1c] text-white relative overflow-hidden">
  <!-- Isometric Pattern -->
  <div class="absolute inset-0 isometric-pattern opacity-[0.02] pointer-events-none"></div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 lg:gap-16 max-w-[1800px] mx-auto relative z-10">
    <!-- Logo & Copyright -->
    <div class="col-span-1 lg:col-span-2 flex flex-col gap-6 lg:gap-10">
      <a href="/" class="flex items-center gap-4 group cursor-pointer">
        <AnimatedLogo trigger="scroll" size="medium" className="footer-logo" />
      </a>
      <p class="text-white/50 font-['Space_Grotesk'] text-[10px] lg:text-[11px] tracking-[0.3em] uppercase font-bold leading-relaxed max-w-[250px]">
        © 2026 BROOKLYN SERVICES. <br/>PRECISION ENGINEERED INFRASTRUCTURE SOLUTIONS.
      </p>
      <p class="text-white/40 font-['Inter'] text-xs">
        Licensed plumbers and drainlayers serving Canterbury & the South Island since 2011.
      </p>
    </div>
    
    <!-- Expertise -->
    <div class="flex flex-col gap-4 lg:gap-6">
      <h5 class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black mb-2">Expertise</h5>
      {expertiseLinks.map((link) => (
        <a 
          href={link.href}
          class="text-white/60 hover:text-white hover:translate-x-2 transition-all text-xs lg:text-sm font-bold uppercase tracking-wider inline-block"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Service Areas -->
    <div class="flex flex-col gap-4 lg:gap-6">
      <h5 class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black mb-2">Areas Served</h5>
      {areaLinks.map((link) => (
        <a 
          href={link.href}
          class="text-white/60 hover:text-white hover:translate-x-2 transition-all text-xs lg:text-sm font-bold uppercase tracking-wider inline-block"
        >
          {link.label}
        </a>
      ))}
      <a href="/areas/" class="text-[#CD5C5C] hover:text-[#CD5C5C]/80 transition-colors text-xs font-bold uppercase tracking-wider inline-block mt-2">
        View All Areas →
      </a>
    </div>
    
    <!-- Resources -->
    <div class="flex flex-col gap-4 lg:gap-6">
      <h5 class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black mb-2">Resources</h5>
      {resourceLinks.map((link) => (
        <a 
          href={link.href}
          class="text-white/60 hover:text-white hover:translate-x-2 transition-all text-xs lg:text-sm font-bold uppercase tracking-wider inline-block"
        >
          {link.label}
        </a>
      ))}
    </div>
    
    <!-- Regulatory -->
    <div class="flex flex-col gap-4 lg:gap-6">
      <h5 class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black mb-2">Regulatory</h5>
      {regulatoryLinks.map((link) => (
        <a 
          href={link.href}
          class="text-white/60 hover:text-white hover:translate-x-2 transition-all text-xs lg:text-sm font-bold uppercase tracking-wider inline-block"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
  
  <!-- Bottom Section -->
  <div class="max-w-[1800px] mx-auto mt-16 pt-8 border-t border-white/10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Emergency Contact -->
      <div class="text-center md:text-left">
        <p class="text-white/50 text-xs uppercase tracking-wider font-['Space_Grotesk'] font-bold mb-1">Emergency Line</p>
        <a href="tel:0800127665" class="text-white font-['Space_Grotesk'] font-bold text-xl hover:text-[#CD5C5C] transition-colors">
          0800 1 BROOK
        </a>
      </div>
      
      <!-- Secure Channels -->
      <div class="flex items-center gap-4">
        <a 
          href="https://www.facebook.com/BrooklynServicesLtd"
          target="_blank"
          rel="noopener noreferrer"
          class="w-12 h-12 bg-white/5 flex items-center justify-center hover:bg-[#CD5C5C] transition-all cursor-pointer skew-block hover:scale-110 shadow-lg group"
          aria-label="Follow us on Facebook"
        >
          <span class="material-symbols-outlined text-xl lg:text-2xl skew-block-content group-hover:text-white">share</span>
        </a>
        <a 
          href="mailto:sam@brooklynservices.co.nz"
          class="w-12 h-12 bg-white/5 flex items-center justify-center hover:bg-[#CD5C5C] transition-all cursor-pointer skew-block hover:scale-110 shadow-lg group"
          aria-label="Email us"
        >
          <span class="material-symbols-outlined text-xl lg:text-2xl skew-block-content group-hover:text-white">mail</span>
        </a>
      </div>
    </div>
  </div>
</footer>

<div class="footer-brand">
  <div class="mini-logo-grid">
    <div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-active" style="--active-color:#8B78E6;animation-delay:0.1s"></div><div class="mini-dot-active" style="--active-color:#8B78E6;animation-delay:0.2s"></div><div class="mini-dot-blank"></div><div class="mini-dot-blank"></div><div class="mini-dot-active" style="--active-color:#5EEAD4;animation-delay:1.1s"></div><div class="mini-dot-active" style="--active-color:#5EEAD4;animation-delay:1.2s"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div>
    <div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-active" style="--active-color:#8B78E6;animation-delay:0.3s"></div><div class="mini-dot-blank"></div><div class="mini-dot-active" style="--active-color:#8B78E6;animation-delay:0.4s"></div><div class="mini-dot-blank"></div><div class="mini-dot-active" style="--active-color:#5EEAD4;animation-delay:1.3s"></div><div class="mini-dot-blank"></div><div class="mini-dot-active" style="--active-color:#5EEAD4;animation-delay:1.4s"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div>
    <div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-active" style="--active-color:#8B78E6;animation-delay:0.5s"></div><div class="mini-dot-active" style="--active-color:#8B78E6;animation-delay:0.6s"></div><div class="mini-dot-blank"></div><div class="mini-dot-blank"></div><div class="mini-dot-active" style="--active-color:#5EEAD4;animation-delay:1.5s"></div><div class="mini-dot-blank"></div><div class="mini-dot-active" style="--active-color:#5EEAD4;animation-delay:1.6s"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div>
    <div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-active" style="--active-color:#8B78E6;animation-delay:0.7s"></div><div class="mini-dot-blank"></div><div class="mini-dot-active" style="--active-color:#8B78E6;animation-delay:0.8s"></div><div class="mini-dot-blank"></div><div class="mini-dot-active" style="--active-color:#5EEAD4;animation-delay:1.7s"></div><div class="mini-dot-blank"></div><div class="mini-dot-active" style="--active-color:#5EEAD4;animation-delay:1.8s"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div>
    <div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-active" style="--active-color:#8B78E6;animation-delay:0.9s"></div><div class="mini-dot-active" style="--active-color:#8B78E6;animation-delay:1.0s"></div><div class="mini-dot-blank"></div><div class="mini-dot-blank"></div><div class="mini-dot-active" style="--active-color:#5EEAD4;animation-delay:1.9s"></div><div class="mini-dot-active" style="--active-color:#5EEAD4;animation-delay:2.0s"></div><div class="mini-dot-blank"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div><div class="mini-dot-faint"></div>
  </div>
  <a href="https://www.bytedigital.co.nz/" class="footer-brand-link" target="_blank" rel="noopener noreferrer">
    <div class="brand-text">Made with <span class="heart">&#10084;&#65039;</span> by <span class="brand-name"><span style="color:#8B78E6">BYTE</span><span style="color:#5EEAD4">DIGITAL</span></span></div>
  </a>
  <div class="brand-sub">Digital solutions for local businesses. Christchurch, New Zealand.</div>
</div>

<style>
  .footer-logo .logo-text-brooklyn {
    color: #E53935 !important;
  }
  .footer-logo .logo-text-services {
    color: #9CA3AF !important;
  }

  .footer-brand {
    background: #0a0a0b;
    border-top: 1px solid rgba(255,255,255,0.04);
    padding: 40px 0;
    text-align: center;
  }

  .mini-logo-grid {
    display: grid;
    grid-template-columns: repeat(15, 5px);
    gap: 2px;
    justify-content: center;
    margin-bottom: 16px;
  }

  .mini-dot-faint {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: rgba(139,120,230,0.12);
    opacity: 0.15;
  }

  .mini-dot-active {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: #1a1a24;
    opacity: 0.15;
    animation: logo-populate 4s infinite;
  }

  .mini-dot-blank {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: transparent;
  }

  .footer-brand .brand-text {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 6px;
    font-family: 'Inter', sans-serif;
  }

  .footer-brand .brand-text .heart {
    color: #ef4444;
    font-size: 14px;
  }

  .footer-brand .brand-name {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .footer-brand-link {
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-brand-link:hover .brand-name span {
    filter: brightness(1.2);
  }

  .footer-brand-link:hover .brand-text .heart {
    transform: scale(1.2);
    display: inline-block;
    transition: transform 0.2s;
  }

  .footer-brand .brand-sub {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    font-family: 'Inter', sans-serif;
  }

  @keyframes logo-populate {
    0%, 10%, 100% { opacity: 0.15; background-color: #1a1a24; box-shadow: none; }
    25%, 85% { opacity: 1; background-color: var(--active-color); box-shadow: 0 0 12px var(--active-color); }
  }
</style>
