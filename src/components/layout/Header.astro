---
import AnimatedLogo from '../ui/AnimatedLogo.astro';

const navItems = [
  { label: 'Services', href: '/services/', hasDropdown: true },
  { label: 'Projects', href: '/projects/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Areas', href: '/areas/' },
  { label: 'About', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
];

const serviceLinks = [
  { label: 'Plumbing', href: '/services/plumbing/', icon: 'plumbing', desc: 'Licensed plumbing for residential & commercial' },
  { label: 'Drainage', href: '/services/drainage/', icon: 'water_damage', desc: 'Drainlaying, CCTV, blocked drains' },
  { label: 'Utility Locating', href: '/services/utility-locating/', icon: 'radar', desc: 'GPR scanning & cable detection' },
  { label: 'Leak Detection', href: '/services/leak-detection/', icon: 'search', desc: 'Acoustic & thermal imaging' },
];

const areaLinks = [
  { label: 'Christchurch', href: '/areas/christchurch/' },
  { label: 'Rolleston', href: '/areas/rolleston/' },
  { label: 'Lincoln', href: '/areas/lincoln/' },
  { label: 'Rangiora', href: '/areas/rangiora/' },
  { label: 'Kaiapoi', href: '/areas/kaiapoi/' },
  { label: 'Ashburton', href: '/areas/ashburton/' },
];

const currentPath = Astro.url.pathname;
---

<!-- Sticky Glassmorphism Nav -->
<nav class="fixed top-0 w-full z-50 glass-nav border-b border-primary/10">
  <div class="flex justify-between items-center w-full px-8 py-5 max-w-screen-2xl mx-auto">
    <a href="/" class="text-2xl font-black tracking-tighter text-stone-900 font-headline flex items-center gap-3 group cursor-pointer hover:opacity-80 transition-opacity">
      <AnimatedLogo trigger="load" size="medium" />
    </a>
    <div class="hidden md:flex gap-10 items-center">
      {navItems.map((item) => (
        <div class="relative group/nav">
          <a 
            href={item.href}
            class="text-stone-600 font-bold font-label tracking-tight uppercase hover:text-primary transition-colors duration-300 text-sm flex items-center gap-1"
          >
            {item.label}
            {item.hasDropdown && <span class="material-symbols-outlined text-lg transition-transform group-hover/nav:rotate-180">expand_more</span>}
          </a>
          
          {item.hasDropdown && (
            <div class="absolute top-full left-1/2 -translate-x-1/2 pt-4 opacity-0 invisible group-hover/nav:opacity-100 group-hover/nav:visible transition-all duration-300">
              <div class="bg-white shadow-2xl border border-[#CD5C5C]/10 p-6 min-w-[320px]">
                <div class="grid gap-3">
                  {serviceLinks.map((service) => (
                    <a 
                      href={service.href}
                      class="flex items-start gap-4 p-3 hover:bg-[#f6f3f2] rounded transition-colors"
                    >
                      <span class="material-symbols-outlined text-[#CD5C5C] text-2xl flex-shrink-0">{service.icon}</span>
                      <div>
                        <span class="font-['Space_Grotesk'] font-bold text-[#1b1b1c] uppercase text-sm block">{service.label}</span>
                        <span class="text-[#564241] text-xs font-['Inter']">{service.desc}</span>
                      </div>
                    </a>
                  ))}
                </div>
                <div class="mt-4 pt-4 border-t border-[#CD5C5C]/10">
                  <a href="/services/" class="text-[#CD5C5C] font-['Space_Grotesk'] font-bold uppercase text-xs tracking-wider hover:underline flex items-center gap-1">
                    View All Services <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  </a>
                </div>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
    <a href="/contact/" class="bg-primary text-on-primary px-8 py-3.5 font-label font-bold uppercase tracking-wider text-xs skew-block hover:brightness-110 active:scale-95 transition-all hidden md:flex items-center">
      Book a Service
    </a>
    
    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 hover:bg-surface-container transition-colors"
      aria-label="Toggle menu"
    >
      <span class="material-symbols-outlined text-2xl">menu</span>
    </button>
  </div>
  
  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-surface border-t border-primary/10">
    <div class="px-8 py-4 space-y-4">
      {navItems.map((item) => (
        <div>
          <a 
            href={item.href}
            class="block text-stone-600 font-bold font-label tracking-tight uppercase hover:text-primary transition-colors text-sm"
          >
            {item.label}
          </a>
          {item.hasDropdown && (
            <div class="pl-4 mt-2 space-y-2 border-l-2 border-[#CD5C5C]/20">
              {serviceLinks.map((service) => (
                <a 
                  href={service.href}
                  class="block text-stone-500 hover:text-[#CD5C5C] transition-colors text-xs font-['Space_Grotesk'] uppercase"
                >
                  {service.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <div class="pt-4 border-t border-primary/10">
        <p class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs uppercase tracking-wider font-bold mb-2">Areas We Serve</p>
        <div class="grid grid-cols-2 gap-2">
          {areaLinks.map((area) => (
            <a 
              href={area.href}
              class="text-stone-500 hover:text-[#CD5C5C] transition-colors text-xs font-['Space_Grotesk'] uppercase"
            >
              {area.label}
            </a>
          ))}
        </div>
      </div>
      <a href="/contact/" class="w-full bg-primary text-on-primary px-8 py-3.5 font-label font-bold uppercase tracking-wider text-xs skew-block hover:brightness-110 active:scale-95 transition-all mt-4 flex items-center justify-center">
        Book a Service
      </a>
    </div>
  </div>
</nav>

<!-- Spacer to push content below fixed header -->
<div class="h-[80px]"></div>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
      const icon = mobileMenuBtn.querySelector('.material-symbols-outlined');
      if (icon) {
        icon.textContent = mobileMenu.classList.contains('hidden') ? 'menu' : 'close';
      }
    });
  }
</script>
