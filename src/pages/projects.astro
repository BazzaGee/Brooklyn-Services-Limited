---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Gallery from '../components/ui/Gallery.astro';
import HorizontalScroll from '../components/ui/HorizontalScroll.astro';

const title = "Projects | Brooklyn Services - Infrastructure Portfolio";
const description = "View our infrastructure projects across Canterbury. Commercial plumbing, drainage, and utility locating for Summerset Villages, Ryman Healthcare, CCL Construction and more.";

const projects = [
  {
    category: "Retirement Development",
    title: "Summerset Villages",
    description: "Currently carrying out plumbing and drainlaying for villa construction at Summerset on Cavendish (Casebrook) and Summerset Avonhead. Ongoing partnership delivering quality infrastructure for retirement living.",
    services: ["Plumbing", "Drainage", "New Build"],
    scale: "Multi-Site",
    image: "/images/services/plumbing/commercial-boiler-replacement.jpg"
  },
  {
    category: "Healthcare Infrastructure",
    title: "Ryman Healthcare",
    description: "Specialized plumbing and drainage solutions for aged care facilities across Christchurch. Emergency response systems and ongoing maintenance protocols for critical healthcare infrastructure.",
    services: ["Plumbing", "Drainage", "Maintenance"],
    scale: "Multi-Site",
    image: "/images/services/plumbing/commercial-maintenance-2.jpeg"
  },
  {
    category: "Construction & Subdivision",
    title: "CCL Construction Contracting",
    description: "Providing utility locating services for Cashmere Estates development and Castle Hill development. Full utility mapping and survey services for new construction projects.",
    services: ["Utility Locating", "Survey"],
    scale: "Major Development",
    image: "/images/services/utility-locating/new-drain-locate-2.jpg"
  },
  {
    category: "Infrastructure Maintenance",
    title: "Facilities Management",
    description: "Plumbing, gas, and drainage maintenance for major facilities management companies including Spotless Services, Neda Facilities Management, and OCS.",
    services: ["Plumbing", "Gas Fitting", "Drainage"],
    scale: "Multi-Client",
    image: "/images/services/drainage/drainage-work-3.jpeg"
  },
  {
    category: "Property Services",
    title: "Property Management",
    description: "Services to various property management clients around Canterbury. Quick, friendly, and efficient service focused on tenant satisfaction and minimal disruption.",
    services: ["Plumbing", "Drainage", "Maintenance"],
    scale: "Canterbury-Wide",
    image: "/images/services/plumbing/rural-plumbing-repairs.jpg"
  },
  {
    category: "Housing Programs",
    title: "Maiden Construction",
    description: "Housing repair programs and various construction projects. Comprehensive plumbing and drainage solutions for residential repair and rebuild programs.",
    services: ["Plumbing", "Drainage", "Repairs"],
    scale: "Program-Wide",
    image: "/images/services/drainage/drainage-work-1.jpg"
  },
];

const currentProjects = [
  { name: "Summerset on Cavendish", detail: "Plumbing & drainlaying for villa construction — Casebrook" },
  { name: "Summerset Avonhead", detail: "Ongoing plumbing and drainage maintenance" },
  { name: "CCL Cashmere Estates", detail: "Utility locating services for new development" },
  { name: "CCL Castle Hill", detail: "Utility locating and survey services" },
  { name: "Gas Hot Water Conversions", detail: "Gas installations and Rinnai/Electrolux service work" },
  { name: "Ryman Healthcare Villages", detail: "Ongoing plumbing and drainage maintenance — Christchurch" },
];

const testimonials = [
  {
    text: "They attended our property on the same day. They inspected our hot water cylinder, determined the cause of the leak and ordered a new cylinder the same afternoon. The replacement arrived a couple of days later and they installed it immediately.",
    author: "M.C.",
    role: "Homeowner, Christchurch",
    service: "Emergency Hot Water Cylinder"
  },
  {
    text: "Thanks for being such a friendly plumber who was willing to go the extra mile! So nice to see a happy tradesperson who went under the floor of my house with no complaints. You even thought ahead and went to purchase the parts needed BEFORE arriving at the job!!",
    author: "Customer Review",
    role: "Residential",
    service: "Plumbing Maintenance"
  },
  {
    text: "The team at Brooklyn Services have been a pleasure to deal with. They were quick to quote and answer any questions, and the work was booked in without delay. Would recommend to anyone looking for reliable service.",
    author: "Verified Customer",
    role: "Whole House Replumb",
    service: "Major Plumbing Project"
  },
  {
    text: "Prompt reliable service.",
    author: "J.E.",
    role: "Christchurch",
    service: "General Plumbing"
  },
  {
    text: "Great little company, good team, very friendly.",
    author: "J.M.",
    role: "Christchurch",
    service: "General Plumbing"
  },
  {
    text: "Good professional.",
    author: "K.D.",
    role: "Christchurch",
    service: "Plumbing Service"
  },
];

const facebookImages = [
  { src: '/images/facebook/fb-01.jpg', alt: 'Brooklyn Services work photo 1' },
  { src: '/images/facebook/fb-02.jpg', alt: 'Brooklyn Services work photo 2' },
  { src: '/images/facebook/fb-03.jpg', alt: 'Brooklyn Services work photo 3' },
  { src: '/images/facebook/fb-04.jpg', alt: 'Brooklyn Services work photo 4' },
  { src: '/images/facebook/fb-05.jpg', alt: 'Brooklyn Services work photo 5' },
  { src: '/images/facebook/fb-06.jpg', alt: 'Brooklyn Services work photo 6' },
  { src: '/images/facebook/fb-07.jpg', alt: 'Brooklyn Services work photo 7' },
  { src: '/images/facebook/fb-08.jpg', alt: 'Brooklyn Services work photo 8' },
  { src: '/images/facebook/fb-09.jpg', alt: 'Brooklyn Services work photo 9' },
  { src: '/images/facebook/fb-10.jpg', alt: 'Brooklyn Services work photo 10' },
  { src: '/images/facebook/fb-11.jpg', alt: 'Brooklyn Services work photo 11' },
  { src: '/images/facebook/fb-12.jpg', alt: 'Brooklyn Services work photo 12' },
];

const stats = [
  { value: "1000+", label: "Projects Completed" },
  { value: "14+", label: "Major Clients" },
  { value: "50+", label: "Combined Years Exp" },
  { value: "4.5/5", label: "Google Rating" },
];
---

<Layout title={title} description={description}>
  <div class="fixed inset-0 isometric-pattern pointer-events-none z-0"></div>
  
  <Header />
  
  <main class="relative z-10 space-y-0 pb-20 max-w-[1800px] mx-auto">
    
    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 min-h-[600px]">
      <div class="md:col-span-7 bg-[#1b1b1c] p-12 lg:p-20 flex flex-col justify-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[#CD5C5C]/20 to-transparent"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-6 mb-8">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Portfolio</span>
          </div>
          <h1 class="font-['Space_Grotesk'] font-black text-5xl lg:text-7xl text-white tracking-tighter leading-[0.9] uppercase mb-6">
            Project<br/><span class="text-[#CD5C5C]">Showcase</span>
          </h1>
          <p class="text-white/70 text-xl max-w-lg leading-relaxed font-light font-['Inter']">
            Infrastructure solutions delivered across Canterbury — from retirement village developments to commercial construction and residential maintenance.
          </p>
        </div>
      </div>
      <div class="md:col-span-5 bg-[#CD5C5C] p-12 lg:p-16 flex flex-col justify-end tetris-module-alt relative">
        <div class="grid grid-cols-2 gap-6">
          {stats.map(stat => (
            <div class="bg-white/10 p-6 skew-block group hover:bg-white/20 transition-colors">
              <div class="skew-block-content">
                <div class="font-['Space_Grotesk'] font-black text-4xl text-white mb-1">{stat.value}</div>
                <div class="text-white/80 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">{stat.label}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28 bg-[#e5e2e1]">
      <div class="max-w-6xl mx-auto px-8">
        <div class="text-center mb-16">
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Active</span>
          <h2 class="font-['Space_Grotesk'] font-black text-4xl text-[#1b1b1c] uppercase mt-4 tracking-tight">
            Current Projects
          </h2>
        </div>
        <div class="space-y-0">
          {currentProjects.map((project, index) => (
            <div class={`flex items-center gap-6 py-5 ${index < currentProjects.length - 1 ? 'border-b border-[#CD5C5C]/10' : ''} group`}>
              <div class="w-3 h-3 bg-[#CD5C5C] skew-block flex-shrink-0 group-hover:scale-150 transition-transform"></div>
              <div class="flex-1">
                <h3 class="font-['Space_Grotesk'] font-black text-[#1b1b1c] uppercase tracking-tight">{project.name}</h3>
                <p class="text-[#564241] text-sm font-['Inter'] mt-1">{project.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <section class="px-4">
      <div class="grid grid-cols-1 gap-6">
        {projects.map((project, index) => (
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-0 overflow-hidden ${index % 2 === 0 ? 'bg-[#f6f3f2]' : 'bg-[#1b1b1c]'} hover:shadow-ambient transition-all duration-500`}>
            <div class={`relative h-64 lg:h-full min-h-[300px] ${index % 2 === 1 ? 'lg:order-2' : ''}`}>
              <img 
                src={project.image} 
                alt={project.title}
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
              />
              <div class={`absolute inset-0 ${index % 2 === 0 ? 'bg-gradient-to-r from-transparent to-[#f6f3f2]/20' : 'bg-gradient-to-r from-transparent to-[#1b1b1c]/20'} lg:hidden`}></div>
            </div>
            
            <div class={`p-8 lg:p-12 xl:p-16 flex flex-col justify-center ${index % 2 === 1 ? 'lg:order-1' : ''}`}>
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-1.5 bg-[#CD5C5C] skew-block"></div>
                <span class="font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black text-[#CD5C5C]">
                  {project.category}
                </span>
              </div>
              
              <h2 class={`font-['Space_Grotesk'] font-black text-2xl lg:text-3xl xl:text-4xl uppercase mb-4 tracking-tight ${index % 2 === 0 ? 'text-[#1b1b1c]' : 'text-white'}`}>
                {project.title}
              </h2>
              
              <p class={`text-base lg:text-lg leading-relaxed mb-6 font-['Inter'] ${index % 2 === 0 ? 'text-[#564241]' : 'text-white/70'}`}>
                {project.description}
              </p>
              
              <div class="flex flex-wrap gap-2 mb-6">
                {project.services.map(service => (
                  <span class={`px-3 py-1 text-xs font-['Space_Grotesk'] uppercase tracking-wider font-bold ${index % 2 === 0 ? 'bg-[#CD5C5C]/10 text-[#CD5C5C]' : 'bg-white/10 text-white'}`}>
                    {service}
                  </span>
                ))}
              </div>
              
              <div class="flex items-center gap-8 pt-6 border-t border-white/10">
                <div>
                  <span class={`text-xs uppercase tracking-wider font-['Space_Grotesk'] font-bold ${index % 2 === 0 ? 'text-[#564241]' : 'text-white/50'}`}>Scale</span>
                  <span class={`font-['Space_Grotesk'] font-bold ml-2 ${index % 2 === 0 ? 'text-[#1b1b1c]' : 'text-white'}`}>{project.scale}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
    
    <section class="py-16 lg:py-24 bg-[#e5e2e1] mt-8 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <div class="flex items-center justify-center gap-6 mb-6">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Partners</span>
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          </div>
          <h2 class="font-['Space_Grotesk'] font-black text-4xl text-[#1b1b1c] uppercase tracking-tight">
            Trusted By Industry Leaders
          </h2>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 lg:gap-4 mb-0">
          <div class="bg-white p-5 lg:p-6 flex items-center justify-center group hover:shadow-lg transition-all rounded-lg">
            <div class="text-center">
              <img src="/images/logos/summerset-villages.png" alt="Summerset Villages" class="h-9 lg:h-11 mx-auto mb-2 object-contain" />
              <span class="block text-xs uppercase tracking-wider text-[#564241] font-['Space_Grotesk'] font-bold">Villages</span>
            </div>
          </div>
          <div class="bg-white p-5 lg:p-6 flex items-center justify-center group hover:shadow-lg transition-all rounded-lg">
            <div class="text-center">
              <img src="/images/logos/ryman-healthcare.svg" alt="Ryman Healthcare" class="h-9 lg:h-11 mx-auto mb-2 object-contain" />
              <span class="block text-xs uppercase tracking-wider text-[#564241] font-['Space_Grotesk'] font-bold">Healthcare</span>
            </div>
          </div>
          <div class="bg-white p-5 lg:p-6 flex items-center justify-center group hover:shadow-lg transition-all rounded-lg">
            <div class="text-center">
              <img src="/images/logos/rinnai.svg" alt="Rinnai" class="h-7 lg:h-9 mx-auto mb-1.5 object-contain" />
              <img src="/images/rinnai-badge.png" alt="Rinnai Authorized Service Centre" class="h-5 lg:h-7 mx-auto mb-1 opacity-75" />
              <span class="block text-xs uppercase tracking-wider text-[#564241] font-['Space_Grotesk'] font-bold">Authorized Agent</span>
            </div>
          </div>
          <div class="bg-white p-5 lg:p-6 flex items-center justify-center group hover:shadow-lg transition-all rounded-lg">
            <div class="text-center">
              <img src="/images/logos/electrolux.svg" alt="Electrolux" class="h-7 lg:h-9 mx-auto mb-1.5 object-contain" />
              <span class="block text-xs uppercase tracking-wider text-[#564241] font-['Space_Grotesk'] font-bold">Authorized Agent</span>
            </div>
          </div>
        </div>
        
        <style>
          .partners-scroll .hscroll-track {
            padding-top: 0.25rem;
            padding-bottom: 0.25rem;
          }
          .partners-scroll-wrapper {
            margin-top: -0.75rem;
          }
        </style>
        
        <div class="partners-scroll-wrapper">
        <HorizontalScroll bgColor="#e5e2e1" class="partners-scroll">
          {[
            { name: 'Tonkin & Taylor', logo: '/images/logos/tonkin-taylor.png' },
            { name: 'Downer Group', logo: '/images/logos/downer-group.png' },
            { name: 'Fulton Hogan', logo: '/images/logos/fulton-hogan.png' },
            { name: 'Mainmark', logo: '/images/logos/mainmark.png' },
            { name: 'Ventia', logo: '/images/logos/ventia.svg' },
            { name: 'CCL Construction', logo: '/images/logos/ccl-construction.png' },
            { name: 'Spotless Services', logo: '/images/logos/spotless-services.png' },
            { name: 'Neda Facilities', logo: '/images/logos/neda-facilities.png' },
            { name: 'OCS', logo: '/images/logos/ocs.png' },
            { name: 'Maiden Construction', logo: '/images/logos/maiden-construction.png' }
          ].map(client => (
            <div class="bg-white p-5 flex flex-col items-center justify-center group hover:shadow-md transition-all rounded-lg" style="min-width: 200px; height: 90px;">
              <img src={client.logo} alt={client.name} class="h-7 mx-auto mb-2 object-contain" />
              <span class="font-['Space_Grotesk'] font-bold text-[10px] lg:text-xs text-[#564241] group-hover:text-[#CD5C5C] transition-colors text-center uppercase tracking-wider">{client.name}</span>
            </div>
          ))}
        </HorizontalScroll>
        </div>
      </div>
    </section>
    
    <section class="py-20 lg:py-28 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <div class="flex items-center justify-center gap-6 mb-8">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">226+ Reviews</span>
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          </div>
          <h2 class="font-['Space_Grotesk'] font-black text-4xl text-[#1b1b1c] uppercase tracking-tight">
            Customer Feedback
          </h2>
          <div class="flex items-center justify-center gap-2 mt-4">
            {[1,2,3,4,5].map(() => (
              <span class="material-symbols-outlined text-[#CD5C5C] text-2xl">star</span>
            ))}
            <span class="font-['Space_Grotesk'] font-bold text-[#1b1b1c] ml-2">4.5/5 on Google</span>
          </div>
        </div>
        
        <HorizontalScroll bgColor="#fcf9f8">
          {testimonials.map(testimonial => (
            <div class="bg-[#f6f3f2] p-8 group hover:bg-white hover:shadow-ambient transition-all" style="min-width: 360px; max-width: 400px;">
              <div class="flex gap-1 mb-4">
                {[1,2,3,4,5].map(() => (
                  <span class="material-symbols-outlined text-[#CD5C5C] text-sm">star</span>
                ))}
              </div>
              <p class="text-[#564241] font-['Inter'] mb-6 leading-relaxed text-sm">
                "{testimonial.text}"
              </p>
              <div class="flex items-center justify-between">
                <div>
                  <div class="font-['Space_Grotesk'] font-bold text-[#1b1b1c] uppercase text-sm tracking-wider">{testimonial.author}</div>
                  <div class="text-xs text-[#564241] font-['Inter']">{testimonial.role}</div>
                </div>
                <span class="px-3 py-1 bg-[#CD5C5C]/10 text-[#CD5C5C] text-xs font-['Space_Grotesk'] uppercase tracking-wider font-bold">{testimonial.service}</span>
              </div>
            </div>
          ))}
        </HorizontalScroll>
      </div>
    </section>

    <Gallery 
      images={facebookImages}
      title="More Of Our Work"
      subtitle="Photos from our projects shared on Facebook — real work, real results."
      columns={4}
      horizontal={true}
    />
    
    <section class="py-20 lg:py-28 bg-[#CD5C5C] mt-0 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-['Space_Grotesk'] font-black text-white text-4xl lg:text-5xl mb-6 uppercase tracking-tight">
          Start Your Project
        </h2>
        <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto font-['Inter']">
          Discuss your infrastructure requirements with our team. We deliver precision-engineered solutions for projects of all sizes.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/contact/" class="btn-inverse group/btn">
            <span>Initiate Consultation</span>
            <span class="material-symbols-outlined transition-transform group-hover/btn:translate-x-1">arrow_forward</span>
          </a>
          <a href="tel:0800127665" class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest text-sm hover:bg-white/20 transition-colors border border-white/30">
            <span class="material-symbols-outlined">phone</span>
            <span>0800 1 BROOK</span>
          </a>
        </div>
      </div>
    </section>
    
  </main>
  
  <Footer />
</Layout>
