---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import HorizontalScroll from '../components/ui/HorizontalScroll.astro';

const title = "Brooklyn Services | Precision Engineered Infrastructure";
const description = "Licensed plumbers with 50+ years combined experience. Serving Christchurch & Canterbury with plumbing, drainage, utility locating & leak detection. No after-hours call-out fee!";
const keywords = ["plumber Christchurch", "drainage services Canterbury", "leak detection", "utility locating", "Brooklyn Services", "emergency plumbing"];

const sectors = [
  { icon: "school", title: "Educational Hubs", desc: "Specialized hydraulic systems for over 14 regional schools and campuses." },
  { icon: "health_and_safety", title: "Healthcare Grid", desc: "Critical drainage management and utility safety for emergency response centres." },
  { icon: "park", title: "Public Spaces", desc: "Utility locating for community park revitalizations and green space projects." },
  { icon: "apartment", title: "Retirement Living", desc: "Ongoing plumbing and drainage maintenance for Summerset and Ryman villages." },
  { icon: "factory", title: "Commercial Build", desc: "Full-scale infrastructure for new commercial construction and fit-outs." },
  { icon: "domain", title: "Subdivision Dev", desc: "Drainage systems, water mains, and utility locating for new subdivisions." },
  { icon: "store", title: "Retail & Hospitality", desc: "Emergency plumbing and drainage for restaurants, retail, and commercial kitchens." },
  { icon: "house", title: "Residential", desc: "Home plumbing, hot water systems, renovations, and maintenance programmes." },
  { icon: "water_drop", title: "Rural Properties", desc: "Rural plumbing repairs, water supply systems, and wastewater solutions." },
];
---

<Layout title={title} description={description} keywords={keywords}>
  <!-- Isometric Background Layer -->
  <div class="fixed inset-0 isometric-pattern pointer-events-none z-0"></div>
  
  <Header />
  
  <!-- Main content - z-10 so it scrolls behind header (z-100) -->
  <main class="relative z-10 space-y-0 px-4 pb-20 max-w-[1800px] mx-auto">
    
    <!-- Hero Section -->
    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 min-h-[750px] animate-fade-in-up" id="hero">
      <!-- Main Hero Block -->
      <div class="md:col-span-8 relative overflow-hidden bg-[#1b1b1c] tetris-module group">
        <img 
          class="absolute inset-0 w-full h-full object-cover opacity-60 grayscale contrast-125 transition-transform duration-1000 group-hover:scale-105" 
          src="/images/services/drainage/drainage-work-5.jpg" 
          alt="Brooklyn Services drainage work"
        />
        <div class="absolute inset-0 bg-gradient-to-tr from-[#CD5C5C]/50 to-transparent"></div>
        <div class="relative h-full flex flex-col justify-center p-12 lg:p-24">
          <div class="bg-[#CD5C5C] self-start px-5 py-1.5 mb-10 skew-block">
            <span class="text-white font-['Space_Grotesk'] text-xs tracking-[0.4em] uppercase font-black skew-block-content">Infrastructure Intelligence</span>
          </div>
          <h1 class="font-['Space_Grotesk'] font-black text-4xl md:text-5xl lg:text-6xl text-white tracking-tighter leading-[0.95] uppercase">
            PRECISION<br/>
            <span class="bg-[#CD5C5C] text-white px-6 inline-block my-3 skew-block shadow-xl">ENGINEERED</span><br/>
            <span class="opacity-90">INFRASTRUCTURE</span>
          </h1>
        </div>
      </div>
      
      <!-- Hero Sidebar Block -->
      <div class="md:col-span-4 bg-[#CD5C5C] p-12 lg:p-16 flex flex-col justify-end gap-10 tetris-module-alt -ml-4 md:ml-0 md:-mt-6 relative z-20 group hover:translate-x-1 transition-transform duration-300">
        <p class="text-white font-['Inter'] text-2xl font-light leading-snug">
          Advanced hydraulic detection and structural utility mapping for high-tier commercial assets.
        </p>
        <a href="/contact/" class="btn-inverse group/btn">
          <span>Initiate Consultation</span>
          <span class="material-symbols-outlined text-3xl transition-transform group-hover/btn:translate-x-1">arrow_forward</span>
        </a>
      </div>
    </section>
    
    <!-- Services Interlocking Grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-0 mt-8 scroll-reveal" id="services">
      
      <!-- Plumbing Block -->
      <a href="/services/plumbing/" class="md:col-span-7 bg-[#f6f3f2] border-r border-b border-[#CD5C5C]/10 p-12 lg:p-16 group relative overflow-hidden hover:bg-white transition-colors duration-500 block cursor-pointer">
        <div class="absolute top-0 right-0 w-48 h-48 bg-[#CD5C5C]/5 -mr-24 -mt-24 rotate-45 transition-transform duration-700 group-hover:scale-150"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-6 mb-10">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">System 01</span>
          </div>
          <h2 class="font-['Space_Grotesk'] font-black text-5xl lg:text-6xl text-[#1b1b1c] uppercase mb-8 tracking-tight leading-none">
            Plumbing<br/><span class="text-[#CD5C5C]/40 group-hover:text-[#CD5C5C]/60 transition-colors">Dynamics</span>
          </h2>
          <p class="text-[#564241] max-w-lg text-xl leading-relaxed font-light font-['Inter']">
            Precision hydraulic engineering for commercial infrastructure. System-wide diagnostics and proactive maintenance protocols designed for longevity.
          </p>
          <div class="mt-8 flex items-center gap-2 text-[#CD5C5C] font-['Space_Grotesk'] font-bold uppercase text-xs tracking-wider">
            <span>View Plumbing Services</span>
            <span class="material-symbols-outlined text-lg transition-transform group-hover:translate-x-1">arrow_forward</span>
          </div>
          <div class="mt-8 flex gap-5">
            <div class="w-6 h-6 bg-[#CD5C5C] skew-block group-hover:translate-y-[-4px] transition-transform delay-75"></div>
            <div class="w-6 h-6 bg-[#CD5C5C]/40 skew-block group-hover:translate-y-[-4px] transition-transform delay-150"></div>
            <div class="w-6 h-6 bg-[#CD5C5C]/20 skew-block group-hover:translate-y-[-4px] transition-transform delay-225"></div>
          </div>
        </div>
      </a>
      
      <!-- Drainage Block -->
      <a href="/services/drainage/" class="md:col-span-5 bg-[#1b1b1c] p-12 lg:p-16 flex flex-col justify-between group relative overflow-hidden transition-all duration-500 hover:shadow-2xl block cursor-pointer">
        <div class="absolute inset-0 bg-[#CD5C5C] opacity-0 group-hover:opacity-5 transition-opacity"></div>
        <div class="relative z-10">
          <span class="material-symbols-outlined text-[#CD5C5C] text-7xl mb-10 transition-transform group-hover:scale-110 duration-500 block">water_damage</span>
          <h2 class="font-['Space_Grotesk'] font-bold text-4xl lg:text-5xl text-white uppercase tracking-tight leading-none mb-6">Drainage<br/>Logistics</h2>
          <p class="text-white/70 text-lg font-['Inter'] leading-relaxed max-w-sm">Topographical flow mapping and high-capacity drainage solutions for municipal scale projects and industrial complexes.</p>
          <div class="mt-4 flex items-center gap-2 text-[#CD5C5C] font-['Space_Grotesk'] font-bold uppercase text-xs tracking-wider">
            <span>View Drainage Services</span>
            <span class="material-symbols-outlined text-lg transition-transform group-hover:translate-x-1">arrow_forward</span>
          </div>
        </div>
        <div class="relative z-10 mt-12">
          <div class="grid grid-cols-4 gap-1.5 h-3">
            <div class="bg-[#CD5C5C] group-hover:flex-grow transition-all duration-500"></div>
            <div class="bg-[#CD5C5C]/80"></div>
            <div class="bg-[#CD5C5C]/50"></div>
            <div class="bg-white/10"></div>
          </div>
        </div>
      </a>
      
      <!-- Utility Locating -->
      <a href="/services/utility-locating/" class="md:col-span-4 bg-[#e5e2e1] p-12 lg:p-16 border-r border-[#CD5C5C]/10 group block cursor-pointer">
        <h2 class="font-['Space_Grotesk'] font-black text-3xl lg:text-4xl text-[#1b1b1c] uppercase tracking-tight leading-none mb-8 transition-transform group-hover:-translate-y-1">Utility<br/>Locating</h2>
        <p class="text-[#564241] text-sm mb-10 leading-relaxed font-medium">Sub-surface radar mapping (GPR) for risk mitigation during heavy infrastructure development and site preparation.</p>
        <div class="flex items-center gap-2 text-[#CD5C5C] font-['Space_Grotesk'] font-bold uppercase text-xs tracking-wider mb-6">
          <span>View Locating Services</span>
          <span class="material-symbols-outlined text-lg transition-transform group-hover:translate-x-1">arrow_forward</span>
        </div>
        <div class="w-full h-56 bg-[#1b1b1c] overflow-hidden skew-block relative modular-shadow">
          <img 
            class="w-full h-full object-cover opacity-60 grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-110" 
            src="/images/services/utility-locating/new-drain-locate-1.jpg" 
            alt="Utility locating service"
          />
          <div class="absolute inset-0 border-[3px] border-[#CD5C5C]/30 group-hover:border-[#CD5C5C]/60 transition-colors"></div>
        </div>
      </a>
      
      <!-- Leak Detection -->
      <a href="/services/leak-detection/" class="md:col-span-8 bg-[#fcf9f8] p-12 lg:p-16 flex flex-col md:flex-row gap-16 items-center group hover:bg-[#f6f3f2] transition-colors duration-500 block cursor-pointer">
        <div class="flex-1">
          <div class="inline-block bg-[#CD5C5C] text-white px-4 py-1.5 text-xs font-black uppercase tracking-[0.25em] mb-6 skew-block shadow-md">
            <span class="skew-block-content">Detection Suite</span>
          </div>
          <h2 class="font-['Space_Grotesk'] font-black text-5xl lg:text-6xl text-[#1b1b1c] uppercase tracking-tighter mb-8 leading-none">Leak Detection</h2>
          <p class="text-[#564241] font-['Inter'] leading-relaxed text-xl font-light">Non-invasive acoustic profiling and thermal imaging technologies to identify structural vulnerabilities before failure occurs.</p>
          <div class="mt-6 flex items-center gap-2 text-[#CD5C5C] font-['Space_Grotesk'] font-bold uppercase text-xs tracking-wider">
            <span>View Detection Services</span>
            <span class="material-symbols-outlined text-lg transition-transform group-hover:translate-x-1">arrow_forward</span>
          </div>
        </div>
          <div class="grid grid-cols-2 gap-6 w-full md:w-80">
            <div class="p-6 md:p-8 bg-white border border-[#CD5C5C]/10 modular-shadow group-hover:translate-y-[-8px] transition-transform duration-300">
              <div class="font-black text-2xl md:text-3xl lg:text-4xl text-[#CD5C5C] font-['Space_Grotesk']">99.8%</div>
              <div class="text-[10px] md:text-[11px] uppercase font-black tracking-widest mt-2 opacity-60 font-['Space_Grotesk']">Accuracy</div>
            </div>
            <div class="p-6 md:p-8 bg-[#CD5C5C] text-white skew-block modular-shadow group-hover:translate-y-[-12px] transition-transform duration-300 delay-75">
              <div class="font-black text-2xl md:text-3xl lg:text-4xl font-['Space_Grotesk'] skew-block-content">ZERO</div>
              <div class="text-[10px] md:text-[11px] uppercase font-black tracking-widest mt-2 skew-block-content">Impact</div>
            </div>
          </div>
      </a>
    </div>
    
    <!-- Sectors We Serve Section -->
    <section class="mt-16 scroll-reveal" id="sectors">
      <div class="bg-[#e5e2e1] p-1 md:p-0 flex flex-col md:flex-row items-stretch shadow-2xl overflow-hidden">
        <div class="bg-[#CD5C5C] text-white p-12 lg:p-16 md:w-1/4 flex flex-col justify-center tetris-module relative group min-w-[250px]">
          <div class="absolute inset-0 bg-white/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <h3 class="font-['Space_Grotesk'] font-black text-4xl lg:text-5xl uppercase leading-[0.9] mb-8 relative z-10">Sectors<br/>We<br/>Serve</h3>
          <p class="text-base opacity-90 font-medium leading-relaxed relative z-10 font-['Inter']">Brooklyn services connect our community's essential infrastructure across every sector.</p>
        </div>
        <div class="flex-1 bg-[#CD5C5C]/10 p-1">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-1">
            {sectors.slice(0, 6).map((sector) => (
              <div class="bg-white p-8 group hover:bg-[#CD5C5C] transition-all duration-500 cursor-default">
                <div class="w-12 h-12 bg-[#CD5C5C]/10 group-hover:bg-white/20 mb-6 flex items-center justify-center skew-block transition-transform group-hover:scale-110">
                  <span class="material-symbols-outlined text-[#CD5C5C] group-hover:text-white text-2xl skew-block-content">{sector.icon}</span>
                </div>
                <h4 class="font-black uppercase text-sm mb-3 tracking-widest group-hover:text-white font-['Space_Grotesk']">{sector.title}</h4>
                <p class="text-sm text-[#564241] group-hover:text-white/80 leading-relaxed font-['Inter']">{sector.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Sectors Horizontal Scroll (Additional Sectors) -->
    <section class="bg-[#1b1b1c] mt-0">
      <div class="max-w-[1800px] mx-auto px-8 pt-16 lg:pt-20 pb-4">
        <div class="flex items-center gap-6 mb-6">
          <div class="w-12 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">More Sectors</span>
        </div>
      </div>
      <HorizontalScroll bgColor="#1b1b1c">
        {sectors.map((sector) => (
          <div class="bg-[#CD5C5C] p-8 cursor-default" style="min-width: 280px; max-width: 320px;">
            <div class="w-12 h-12 bg-white/20 mb-6 flex items-center justify-center skew-block">
              <span class="material-symbols-outlined text-white text-2xl skew-block-content">{sector.icon}</span>
            </div>
            <h4 class="font-black uppercase text-sm mb-3 tracking-widest text-white font-['Space_Grotesk']">{sector.title}</h4>
            <p class="text-sm text-white/90 leading-relaxed font-['Inter']">{sector.desc}</p>
          </div>
        ))}
      </HorizontalScroll>
    </section>
    
    <!-- Brooklyn Protocol Section -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-0 pt-20 scroll-reveal">
      <div class="bg-[#f6f3f2] p-12 lg:p-20 relative overflow-hidden group">
        <div class="absolute top-0 left-0 w-32 h-32 bg-[#CD5C5C] opacity-5 skew-block -ml-16 -mt-16 transition-transform group-hover:scale-150 duration-1000"></div>
        <h3 class="font-['Space_Grotesk'] font-black text-5xl lg:text-7xl text-[#1b1b1c] uppercase mb-16 tracking-tighter leading-none">The Brooklyn<br/><span class="text-[#CD5C5C] group-hover:translate-x-4 inline-block transition-transform duration-500">Protocol.</span></h3>
        
        <div class="space-y-0">
          <!-- Step 01 -->
          <div class="flex group/step">
            <div class="w-20 flex flex-col items-center">
              <span class="material-symbols-outlined text-2xl text-[#CD5C5C]">sensors</span>
              <div class="w-[3px] flex-1 bg-[#CD5C5C]/20 group-hover/step:bg-[#CD5C5C] transition-colors duration-500"></div>
            </div>
            <div class="pb-16 pl-8">
              <h4 class="font-['Space_Grotesk'] font-black text-[#1b1b1c] uppercase tracking-[0.2em] mb-3 text-base">01 Detection</h4>
              <p class="text-base text-[#564241] max-w-sm leading-relaxed font-light font-['Inter']">Rapid deployment of high-frequency sensor arrays to analyze current infrastructure health and anomalies.</p>
            </div>
          </div>
          
          <!-- Step 02 -->
          <div class="flex group/step">
            <div class="w-20 flex flex-col items-center">
              <span class="material-symbols-outlined text-2xl text-[#CD5C5C]/60 group-hover/step:text-[#CD5C5C] transition-colors">analytics</span>
              <div class="w-[3px] flex-1 bg-[#CD5C5C]/20 group-hover/step:bg-[#CD5C5C] transition-colors duration-500"></div>
            </div>
            <div class="pb-16 pl-8">
              <h4 class="font-['Space_Grotesk'] font-black text-[#1b1b1c] uppercase tracking-[0.2em] mb-3 text-base">02 Analysis</h4>
              <p class="text-base text-[#564241] max-w-sm leading-relaxed font-light font-['Inter']">Data synthesis and comprehensive engineering review of site-specific hydraulic variables and flow patterns.</p>
            </div>
          </div>
          
          <!-- Step 03 -->
          <div class="flex group/step">
            <div class="w-20 flex flex-col items-center">
              <span class="material-symbols-outlined text-2xl text-[#CD5C5C]/60 group-hover/step:text-[#CD5C5C] transition-colors">construction</span>
            </div>
            <div class="pl-8">
              <h4 class="font-['Space_Grotesk'] font-black text-[#1b1b1c] uppercase tracking-[0.2em] mb-3 text-base">03 Execution</h4>
              <p class="text-base text-[#564241] max-w-sm leading-relaxed font-light font-['Inter']">Surgical intervention using precision-engineered componentry to ensure maximum system integrity.</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- 24/7 Response Image Section -->
      <div class="relative min-h-[600px] overflow-hidden group">
        <img 
          class="absolute inset-0 w-full h-full object-cover grayscale brightness-50 transition-all duration-1000 group-hover:scale-110 group-hover:grayscale-0 group-hover:brightness-75" 
          src="/images/services/plumbing/hot-water-cylinder-replacement.jpeg" 
          alt="24/7 Emergency Response - Hot water cylinder replacement"
        />
        <div class="absolute inset-0 bg-[#CD5C5C]/30 mix-blend-multiply opacity-60 group-hover:opacity-40 transition-opacity"></div>
        <div class="absolute inset-x-0 bottom-0 p-12 lg:p-16 bg-gradient-to-t from-black/90 to-transparent">
          <div class="flex items-center gap-12 text-white">
            <div class="text-5xl md:text-6xl lg:text-7xl font-black font-['Space_Grotesk'] transition-transform group-hover:scale-110 duration-500">24/7</div>
            <div class="h-12 md:h-16 lg:h-20 w-[4px] bg-[#CD5C5C]"></div>
            <p class="text-xs md:text-sm uppercase font-['Space_Grotesk'] font-black tracking-[0.3em] leading-loose max-w-[200px] md:max-w-[240px]">Critical Infrastructure Response Unit Always Active</p>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Trust Stats Section -->
    <section class="bg-[#f6f3f2] mt-16">
      <div class="max-w-[1800px] mx-auto px-8 pt-20 lg:pt-28 pb-4">
        <div class="text-center mb-12">
          <div class="flex items-center justify-center gap-6 mb-6">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">By The Numbers</span>
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          </div>
          <h2 class="font-['Space_Grotesk'] font-black text-4xl lg:text-5xl text-[#1b1b1c] uppercase tracking-tight">
            Trust Metrics
          </h2>
        </div>
      </div>
      <HorizontalScroll bgColor="#f6f3f2">
        <div class="text-center group" style="min-width: 220px;">
          <div class="font-['Space_Grotesk'] font-black text-6xl lg:text-7xl text-[#CD5C5C] mb-2 transition-transform group-hover:scale-110">50+</div>
          <div class="text-sm uppercase tracking-widest text-[#564241] font-['Space_Grotesk'] font-bold">Years Combined</div>
        </div>
        <div class="text-center group" style="min-width: 220px;">
          <div class="font-['Space_Grotesk'] font-black text-6xl lg:text-7xl text-[#CD5C5C] mb-2 transition-transform group-hover:scale-110">4.7</div>
          <div class="text-sm uppercase tracking-widest text-[#564241] font-['Space_Grotesk'] font-bold">Google Rating</div>
        </div>
        <div class="text-center group" style="min-width: 220px;">
          <div class="font-['Space_Grotesk'] font-black text-6xl lg:text-7xl text-[#CD5C5C] mb-2 transition-transform group-hover:scale-110">15</div>
          <div class="text-sm uppercase tracking-widest text-[#564241] font-['Space_Grotesk'] font-bold">Reviews</div>
        </div>
        <div class="text-center group" style="min-width: 220px;">
          <div class="font-['Space_Grotesk'] font-black text-6xl lg:text-7xl text-[#CD5C5C] mb-2 transition-transform group-hover:scale-110">1000+</div>
          <div class="text-sm uppercase tracking-widest text-[#564241] font-['Space_Grotesk'] font-bold">Projects Done</div>
        </div>
        <div class="text-center group" style="min-width: 220px;">
          <div class="font-['Space_Grotesk'] font-black text-6xl lg:text-7xl text-[#CD5C5C] mb-2 transition-transform group-hover:scale-110">14+</div>
          <div class="text-sm uppercase tracking-widest text-[#564241] font-['Space_Grotesk'] font-bold">Major Clients</div>
        </div>
        <div class="text-center group" style="min-width: 220px;">
          <div class="font-['Space_Grotesk'] font-black text-6xl lg:text-7xl text-[#CD5C5C] mb-2 transition-transform group-hover:scale-110">2011</div>
          <div class="text-sm uppercase tracking-widest text-[#564241] font-['Space_Grotesk'] font-bold">Established</div>
        </div>
        <div class="text-center group" style="min-width: 220px;">
          <div class="font-['Space_Grotesk'] font-black text-6xl lg:text-7xl text-[#CD5C5C] mb-2 transition-transform group-hover:scale-110">99.8%</div>
          <div class="text-sm uppercase tracking-widest text-[#564241] font-['Space_Grotesk'] font-bold">Leak Accuracy</div>
        </div>
        <div class="text-center group" style="min-width: 220px;">
          <div class="font-['Space_Grotesk'] font-black text-6xl lg:text-7xl text-[#CD5C5C] mb-2 transition-transform group-hover:scale-110">24/7</div>
          <div class="text-sm uppercase tracking-widest text-[#564241] font-['Space_Grotesk'] font-bold">Response Ready</div>
        </div>
        <div class="text-center group" style="min-width: 220px;">
          <div class="font-['Space_Grotesk'] font-black text-6xl lg:text-7xl text-[#CD5C5C] mb-2 transition-transform group-hover:scale-110">4</div>
          <div class="text-sm uppercase tracking-widest text-[#564241] font-['Space_Grotesk'] font-bold">Service Systems</div>
        </div>
        <div class="text-center group" style="min-width: 220px;">
          <div class="font-['Space_Grotesk'] font-black text-6xl lg:text-7xl text-[#CD5C5C] mb-2 transition-transform group-hover:scale-110">$0</div>
          <div class="text-sm uppercase tracking-widest text-[#564241] font-['Space_Grotesk'] font-bold">After-Hours Fee</div>
        </div>
      </HorizontalScroll>
    </section>
    
    <!-- Google Reviews Section -->
    <section class="bg-[#1b1b1c] mt-0">
      <div class="max-w-[1800px] mx-auto px-8 pt-20 lg:pt-28 pb-4">
        <div class="text-center mb-12">
          <div class="flex items-center justify-center gap-6 mb-6">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Customer Feedback</span>
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          </div>
          <h2 class="font-['Space_Grotesk'] font-black text-4xl lg:text-5xl text-white uppercase tracking-tight mb-4">
            What Our Clients Say
          </h2>
          <div class="flex items-center justify-center gap-2 mb-2">
