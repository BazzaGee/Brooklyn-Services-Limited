---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import HorizontalScroll from '../components/ui/HorizontalScroll.astro';

const title = "About Us | Brooklyn Services - Precision Infrastructure Specialists";
const description = "Learn about Brooklyn Services Limited - Christchurch's trusted plumbing, drainage and detection specialists. Founded by Sam Aitken, named after his son Brooklyn. 50+ years combined experience since 2011.";

const valueProps = [
  { icon: "verified", title: "Licensed Excellence", desc: "Fully licensed plumbers and drainlayers. Authorized service agents for Rinnai (Canterbury-wide) and Electrolux. Every technician carries current certifications.", color: "#1b1b1c" },
  { icon: "schedule", title: "No After-Hours Fee", desc: "Critical infrastructure doesn't follow business hours. 24/7 emergency response without penalty rates — one of the few companies offering this. Fair pricing, always.", color: "#CD5C5C" },
  { icon: "handshake", title: "Trusted Partnerships", desc: "Long-term relationships with businesses that supported us from the start. Preferred contractor for Summerset Villages, Ryman Healthcare, and major construction companies.", color: "#f6f3f2" },
  { icon: "engineering", title: "Multi-Discipline", desc: "Four integrated service divisions — plumbing, drainage, utility locating, and leak detection. One team, one call, complete infrastructure coverage.", color: "#1b1b1c" },
  { icon: "school", title: "Apprentice Programme", desc: "Investing in the next generation. We hire and train apprentices, teaching dedication to quality workmanship and professional standards.", color: "#CD5C5C" },
  { icon: "location_on", title: "South Island Wide", desc: "Based in Christchurch with rapid response across Canterbury. Utility locating and leak detection available across the entire South Island on request.", color: "#f6f3f2" },
  { icon: "analytics", title: "Predictive Approach", desc: "Modern infrastructure demands more than reactive fixes. We use diagnostics, thermal imaging, and data analysis to prevent failures before they occur.", color: "#1b1b1c" },
];

const equipment = [
  { name: "Ground Penetrating Radar", tag: "GPR" },
  { name: "CCTV Drain Cameras", tag: "Inspection" },
  { name: "Acoustic Geophone", tag: "Leak Detection" },
  { name: "Thermal Imaging", tag: "Non-Invasive" },
  { name: "Water Blaster Truck", tag: "Drain Clearing" },
  { name: "Electromagnetic Locator", tag: "Cable Detection" },
  { name: "Sonde Tracking", tag: "Location" },
  { name: "Pipe Inspection Tools", tag: "Diagnostics" },
  { name: "Pressure Testing Kit", tag: "Analysis" },
  { name: "Gas Detection Equipment", tag: "Safety" },
];
---

<Layout title={title} description={description}>
  <div class="fixed inset-0 isometric-pattern pointer-events-none z-0"></div>
  
  <Header />
  
  <main class="relative z-10 space-y-0 px-4 pb-20 max-w-[1800px] mx-auto">
    
    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 min-h-[600px]">
      <div class="md:col-span-5 bg-[#CD5C5C] p-12 lg:p-20 flex flex-col justify-center tetris-module-alt">
        <span class="text-white/80 font-['Space_Grotesk'] text-xs tracking-[0.4em] uppercase font-black mb-6">About Us</span>
        <h1 class="font-['Space_Grotesk'] font-black text-4xl md:text-5xl lg:text-6xl text-white tracking-tighter leading-[0.9] uppercase mb-6">
          Precision<br/>Since<br/>2011
        </h1>
        <p class="text-white/90 text-lg font-light font-['Inter'] leading-relaxed">
          Licensed professionals delivering engineered infrastructure solutions across Canterbury. Founded by Sam Aitken, named after his son Brooklyn.
        </p>
      </div>
      <div class="md:col-span-7 relative overflow-hidden bg-[#1b1b1c] tetris-module min-h-[400px] md:min-h-0">
        <img 
          class="absolute inset-0 w-full h-full object-cover opacity-50 grayscale"
          src="/images/team/team-group.jpg" 
          alt="Brooklyn Services team"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-[#CD5C5C]/30 to-transparent"></div>
      </div>
    </section>
    
    <section class="py-20 lg:py-28 bg-[#f6f3f2] mt-8">
      <div class="max-w-4xl mx-auto px-8">
        <div class="flex items-center gap-6 mb-10">
          <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Our Story</span>
        </div>
        
        <h2 class="font-['Space_Grotesk'] font-black text-4xl lg:text-5xl text-[#1b1b1c] uppercase mb-8 tracking-tight">
          From Apprentice<br/>to Specialist
        </h2>
        
        <div class="space-y-6 text-lg text-[#564241] font-['Inter'] leading-relaxed">
          <p>
            Brooklyn Services was founded by <strong class="text-[#1b1b1c]">Sam Aitken</strong>, a Christchurch plumber and drainlayer who completed a stable apprenticeship before deciding to go out on his own to help the people of Canterbury. The company name "Brooklyn" was chosen in honour of Sam's son.
          </p>
          <p>
            Starting as a sole trader under the name Sam Aitken Plumbing, Sam built his business from a small client base, contracting to local plumbing businesses. Through dedication to quality workmanship and personalised service, the company grew into Brooklyn Services Limited — a multi-service operation offering plumbing, drainage, utility locating, and leak detection.
          </p>
          <p>
            Today, our team brings together <strong class="text-[#1b1b1c]">over 50 years of combined technical expertise</strong>, with licensed plumbers and drainlayers who understand that modern infrastructure demands more than standard maintenance — it requires predictive analytics, non-invasive diagnostics, and precision intervention capabilities.
          </p>
        </div>
      </div>
    </section>
    
    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 mt-8">
      <div class="md:col-span-6 bg-[#1b1b1c] p-12 lg:p-16 flex flex-col justify-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[#CD5C5C]/20 to-transparent"></div>
        <div class="relative z-10">
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black mb-6 block">Philosophy</span>
          <blockquote class="text-white/90 text-2xl lg:text-3xl font-light font-['Inter'] leading-relaxed italic mb-8">
            "As a company we are all about providing you with personalised service and quality of products."
          </blockquote>
          <p class="text-white/70 font-['Inter'] leading-relaxed">
            At Brooklyn Services you'll receive excellent service that you can rely on. When hiring a plumber, drainlayer or utility locator it is essential that you can trust in the people you're dealing with.
          </p>
          <p class="text-white/70 font-['Inter'] leading-relaxed mt-4">
            Our hiring philosophy is simple: work with people that you trust and that you know are reliable and can provide quality results for customers. We hire and train apprentices, teaching dedication to quality workmanship.
          </p>
        </div>
      </div>
      <div class="md:col-span-6 relative overflow-hidden bg-[#f6f3f2]">
        <img 
          class="absolute inset-0 w-full h-full object-cover opacity-40 grayscale"
          src="/images/services/plumbing/commercial-maintenance-1.jpeg" 
          alt="Brooklyn Services commercial work"
        />
        <div class="absolute inset-0 bg-gradient-to-l from-[#f6f3f2]/80 to-transparent"></div>
        <div class="relative z-10 h-full flex flex-col justify-end p-12 lg:p-16">
          <div class="bg-[#CD5C5C] inline-block px-4 py-2 skew-block self-start mb-6">
            <span class="text-white font-['Space_Grotesk'] text-xs font-black uppercase tracking-wider skew-block-content">Do it right, call day and night</span>
          </div>
          <p class="text-[#1b1b1c] font-['Space_Grotesk'] font-black text-sm uppercase tracking-wider">Brooklyn Services Limited</p>
          <p class="text-[#564241] text-sm font-['Inter']">NZBN: 9429031033725 | Est. 2011</p>
        </div>
      </div>
    </section>
    
    <!-- Value Props - Horizontal Scroll -->
    <section class="bg-[#f6f3f2] mt-8">
      <div class="max-w-[1800px] mx-auto px-8 pt-16 lg:pt-20 pb-4">
        <div class="flex items-center gap-6 mb-6">
          <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Why Brooklyn</span>
        </div>
        <h2 class="font-['Space_Grotesk'] font-black text-4xl lg:text-5xl text-[#1b1b1c] uppercase mb-4 tracking-tight">
          Our Advantages
        </h2>
      </div>
      <HorizontalScroll bgColor="#f6f3f2">
        {valueProps.map((prop) => (
          <div class="group transition-all duration-300" style={`min-width: 320px; max-width: 360px; background: ${prop.color}; padding: 2rem;`}>
            <span class={`material-symbols-outlined text-5xl mb-6 block ${prop.color === '#CD5C5C' ? 'text-white' : prop.color === '#1b1b1c' ? 'text-white' : 'text-[#CD5C5C]'}`}>{prop.icon}</span>
            <h3 class={`font-['Space_Grotesk'] font-black text-2xl uppercase mb-4 tracking-tight ${prop.color === '#CD5C5C' ? 'text-white' : prop.color === '#1b1b1c' ? 'text-white' : 'text-[#1b1b1c]'}`}>{prop.title}</h3>
            <p class={`font-['Inter'] leading-relaxed ${prop.color === '#CD5C5C' ? 'text-white/90' : prop.color === '#1b1b1c' ? 'text-white/70' : 'text-[#564241]'}`}>{prop.desc}</p>
          </div>
        ))}
      </HorizontalScroll>
    </section>

    <!-- Equipment & Technology Strip -->
    <section class="bg-[#1b1b1c] mt-0">
      <div class="max-w-[1800px] mx-auto px-8 pt-16 lg:pt-20 pb-4">
        <div class="flex items-center gap-6 mb-6">
          <div class="w-12 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Technology</span>
        </div>
        <h2 class="font-['Space_Grotesk'] font-black text-3xl lg:text-4xl text-white uppercase tracking-tight">
          Our Equipment
        </h2>
      </div>
      <HorizontalScroll bgColor="#1b1b1c">
        {equipment.map((item) => (
          <div class="bg-[#252525] p-6 group hover:bg-[#CD5C5C] transition-all duration-500 flex items-center gap-4" style="min-width: 260px; max-width: 300px;">
            <div class="flex-1">
              <h4 class="font-['Space_Grotesk'] font-black text-sm text-white uppercase tracking-wider group-hover:text-white">{item.name}</h4>
            </div>
            <span class="px-3 py-1 bg-[#CD5C5C]/20 group-hover:bg-white/20 text-[#CD5C5C] group-hover:text-[#CD5C5C] text-xs font-['Space_Grotesk'] uppercase tracking-wider font-bold flex-shrink-0">{item.tag}</span>
          </div>
        ))}
      </HorizontalScroll>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 mt-8">
      <div class="md:col-span-7 bg-[#e5e2e1] p-12 lg:p-20">
        <div class="flex items-center gap-6 mb-10">
          <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Milestones</span>
        </div>
        
        <div class="space-y-0">
          <div class="flex group/step">
            <div class="w-20 flex flex-col items-center">
              <span class="font-['Space_Grotesk'] font-black text-[#CD5C5C] text-lg">2011</span>
              <div class="w-[3px] flex-1 bg-[#CD5C5C]/20 group-hover/step:bg-[#CD5C5C] transition-colors mt-2"></div>
            </div>
            <div class="pb-12 pl-8">
              <h4 class="font-['Space_Grotesk'] font-black text-[#1b1b1c] uppercase tracking-[0.2em] mb-3 text-base">Company Founded</h4>
              <p class="text-[#564241] font-['Inter'] leading-relaxed">Sam Aitken completes apprenticeship and goes out on his own as Sam Aitken Plumbing, later registering Brooklyn Services Limited.</p>
            </div>
          </div>
          
          <div class="flex group/step">
            <div class="w-20 flex flex-col items-center">
              <span class="font-['Space_Grotesk'] font-black text-[#CD5C5C]/60 group-hover/step:text-[#CD5C5C] transition-colors text-lg">Growth</span>
              <div class="w-[3px] flex-1 bg-[#CD5C5C]/20 group-hover/step:bg-[#CD5C5C] transition-colors mt-2"></div>
            </div>
            <div class="pb-12 pl-8">
              <h4 class="font-['Space_Grotesk'] font-black text-[#1b1b1c] uppercase tracking-[0.2em] mb-3 text-base">Multi-Service Expansion</h4>
              <p class="text-[#564241] font-['Inter'] leading-relaxed">Expanded from plumbing-only to include drainage, utility locating, and leak detection services. Built relationships with early supporting businesses.</p>
            </div>
          </div>
          
          <div class="flex group/step">
            <div class="w-20 flex flex-col items-center">
              <span class="font-['Space_Grotesk'] font-black text-[#CD5C5C]/60 group-hover/step:text-[#CD5C5C] transition-colors text-lg">Today</span>
            </div>
            <div class="pl-8">
              <h4 class="font-['Space_Grotesk'] font-black text-[#1b1b1c] uppercase tracking-[0.2em] mb-3 text-base">Canterbury's Trusted Team</h4>
              <p class="text-[#564241] font-['Inter'] leading-relaxed">50+ years combined experience. Hired and training apprentices. Major projects with Summerset Villages, Ryman Healthcare, CCL Construction, and more.</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="md:col-span-5 relative overflow-hidden bg-[#1b1b1c] tetris-module">
        <img 
          class="absolute inset-0 w-full h-full object-cover opacity-50 grayscale group-hover:grayscale-0 transition-all duration-700"
          src="/images/services/utility-locating/cctv-sonde-locate.jpg" 
          alt="Advanced equipment used by Brooklyn Services"
        />
        <div class="absolute inset-0 bg-[#CD5C5C]/20"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8">
          <div class="bg-[#CD5C5C] inline-block px-4 py-2 skew-block">
            <span class="text-white font-['Space_Grotesk'] text-xs font-black uppercase tracking-wider skew-block-content">Latest Technology</span>
          </div>
          <p class="text-white/80 text-sm font-['Inter'] mt-3">GPR, acoustic detection, CCTV, water blaster trucks, and more.</p>
        </div>
      </div>
    </section>
    
    <section class="py-20 lg:py-28 mt-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="flex items-center gap-6 mb-10">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Coverage Area</span>
          </div>
          
          <h2 class="font-['Space_Grotesk'] font-black text-4xl lg:text-5xl text-[#1b1b1c] uppercase mb-8 tracking-tight">
            Canterbury Operations
          </h2>
          
          <p class="text-lg text-[#564241] font-['Inter'] leading-relaxed mb-8">
            Based at 96b Carmen Rd, Hei Hei, Christchurch. Our rapid response units operate across the greater Canterbury region, from Christchurch CBD to surrounding townships. 
            Utility locating and leak detection available South Island-wide on request.
          </p>
          
          <HorizontalScroll bgColor="#fcf9f8">
            {[
              { name: "Christchurch", sub: "CBD & Suburbs" },
              { name: "Rolleston", sub: "Selwyn District" },
              { name: "Lincoln", sub: "Selwyn District" },
              { name: "Kaiapoi", sub: "Waimakariri" },
              { name: "Rangiora", sub: "Waimakariri" },
              { name: "Halswell", sub: "Christchurch" },
              { name: "Prebbleton", sub: "Selwyn District" },
              { name: "West Melton", sub: "Christchurch" },
              { name: "Rakaia", sub: "Ashburton" },
              { name: "Ashburton", sub: "Mid Canterbury" },
            ].map(area => (
              <div class="p-5 bg-[#f6f3f2] border-l-4 border-[#CD5C5C] group hover:bg-white hover:shadow-lg transition-all" style="min-width: 200px;">
                <span class="font-['Space_Grotesk'] font-bold text-[#1b1b1c] uppercase text-sm tracking-wider block">{area.name}</span>
                <span class="text-xs text-[#564241] font-['Inter']">{area.sub}</span>
              </div>
            ))}
          </HorizontalScroll>
        </div>
        
        <div class="relative h-[500px] bg-[#1b1b1c] overflow-hidden skew-block modular-shadow">
          <img 
            class="absolute inset-0 w-full h-full object-cover opacity-60 grayscale group-hover:grayscale-0 transition-all duration-700"
            src="/images/google-maps-business.jpg" 
            alt="Canterbury Service Area"
          />
          <div class="absolute inset-0 bg-[#CD5C5C]/20"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 bg-gradient-to-t from-black/80 to-transparent">
            <div class="flex items-center gap-4">
              <span class="material-symbols-outlined text-[#CD5C5C] text-3xl">location_on</span>
              <div>
                <div class="text-white font-['Space_Grotesk'] font-bold">Headquarters</div>
                <div class="text-white/70 text-sm">96b Carmen Rd, Hei Hei, Christchurch 8042</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <section class="py-20 lg:py-28 bg-[#1b1b1c] mt-8">
      <div class="max-w-4xl mx-auto px-8 text-center">
        <h2 class="font-['Space_Grotesk'] font-black text-white text-4xl lg:text-5xl mb-6 uppercase tracking-tight">
          Connect With Our Team
        </h2>
        <p class="text-white/70 text-lg mb-10 max-w-2xl mx-auto font-['Inter']">
          Discuss your infrastructure requirements with our technical specialists. 
          We provide detailed assessments and engineered solutions.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/contact/" class="btn-actuator">
            <span>Initiate Consultation</span>
          </a>
          <a href="tel:0800127665" class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest text-sm hover:bg-white/20 transition-colors border border-white/30">
            <span class="material-symbols-outlined">phone</span>
            <span>0800 1 BROOK</span>
          </a>
        </div>
      </div>
    </section>
    
  </main>
  
  <Footer />
</Layout>
