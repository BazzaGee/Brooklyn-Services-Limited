---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import FAQ from '../../components/ui/FAQ.astro';

const title = "Plumber in Lincoln | Brooklyn Services - Plumbing & Drainage Selwyn";
const description = "Licensed plumber in Lincoln serving Selwyn District. Rural plumbing, residential services, hot water systems. No after-hours call-out fee. Call 0800 1 BROOK.";
const keywords = ["plumber Lincoln", "plumber Selwyn", "rural plumbing Lincoln", "drainlayer Lincoln Canterbury"];

const faqItems = [
  {
    question: "Do you provide rural plumbing services in Lincoln?",
    answer: "Yes. Lincoln and surrounding areas include many rural and lifestyle properties. We handle rural plumbing systems including water supply systems, wastewater solutions, septic tank installations, and standard residential plumbing. Our team has experience with the unique challenges of rural plumbing in the Selwyn District."
  },
  {
    question: "Can you service Lincoln University and surrounding commercial properties?",
    answer: "Yes. We provide plumbing and drainage services to Lincoln University and surrounding commercial and research facilities. Our commercial plumbing team handles maintenance contracts, emergency repairs, and new installations for all types of commercial properties in Lincoln."
  }
];
---

<Layout title={title} description={description} keywords={keywords}>
  <div class="fixed inset-0 isometric-pattern pointer-events-none z-0"></div>
  
  <Header />
  
  <main class="relative z-10 space-y-0 px-4 pb-20 max-w-[1800px] mx-auto">
    
    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 min-h-[500px]">
      <div class="md:col-span-7 bg-[#1b1b1c] p-12 lg:p-20 flex flex-col justify-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[#CD5C5C]/20 to-transparent"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-6 mb-8">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Service Area</span>
          </div>
          <h1 class="font-['Space_Grotesk'] font-black text-5xl lg:text-7xl text-white tracking-tighter leading-[0.9] uppercase mb-6">
            Lincoln<br/><span class="text-[#CD5C5C]">Plumbing</span>
          </h1>
          <p class="text-white/70 text-xl max-w-xl leading-relaxed font-light font-['Inter']">
            Licensed plumbers serving Lincoln and the Selwyn District. Rural, residential, and commercial plumbing services.
          </p>
          <div class="mt-10 flex gap-4">
            <a href="/contact/" class="btn-actuator">
              <span>Request Service</span>
            </a>
            <a href="tel:0800127665" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest text-xs hover:bg-white/20 transition-colors border border-white/30">
              <span class="material-symbols-outlined">phone</span>
              <span>0800 1 BROOK</span>
            </a>
          </div>
        </div>
      </div>
      <div class="md:col-span-5 bg-[#CD5C5C] p-12 lg:p-16 flex flex-col justify-center tetris-module-alt">
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white/10 p-6 skew-block">
            <div class="skew-block-content">
              <div class="font-['Space_Grotesk'] font-black text-3xl text-white">Same Day</div>
              <div class="text-white/80 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">Response</div>
            </div>
          </div>
          <div class="bg-white p-6 skew-block">
            <div class="skew-block-content">
              <div class="font-['Space_Grotesk'] font-black text-3xl text-[#CD5C5C]">Rural</div>
              <div class="text-[#1b1b1c]/70 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">Specialists</div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <section class="px-4 -mt-4">
      <div class="bg-[#1b1b1c] px-6 py-4">
        <Breadcrumbs items={[{ label: 'Areas', href: '/areas/' }, { label: 'Lincoln' }]} />
      </div>
    </section>
    
    <section class="py-20 lg:py-28 bg-[#f6f3f2] mt-8">
      <div class="max-w-6xl mx-auto px-8">
        <h2 class="font-['Space_Grotesk'] font-black text-3xl text-[#1b1b1c] uppercase mb-6 tracking-tight">
          Lincoln Plumbing Services
        </h2>
        <p class="text-[#564241] text-lg leading-relaxed mb-8 font-['Inter']">
          Serving Lincoln and the surrounding Selwyn District with comprehensive plumbing and drainage solutions for residential, rural, and commercial properties.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white p-8 hover:shadow-lg transition-all">
            <span class="material-symbols-outlined text-[#CD5C5C] text-5xl mb-4 block">house</span>
            <h3 class="font-['Space_Grotesk'] font-black text-xl text-[#1b1b1c] uppercase mb-3">Residential</h3>
            <p class="text-[#564241] text-sm font-['Inter']">Home plumbing, hot water systems, renovations, and maintenance for Lincoln properties.</p>
          </div>
          <div class="bg-[#1b1b1c] p-8 hover:shadow-lg transition-all">
            <span class="material-symbols-outlined text-[#CD5C5C] text-5xl mb-4 block">water_drop</span>
            <h3 class="font-['Space_Grotesk'] font-black text-xl text-white uppercase mb-3">Rural</h3>
            <p class="text-white/70 text-sm font-['Inter']">Rural plumbing, water supply systems, septic tanks, and wastewater solutions for lifestyle properties.</p>
          </div>
          <div class="bg-white p-8 hover:shadow-lg transition-all">
            <span class="material-symbols-outlined text-[#CD5C5C] text-5xl mb-4 block">construction</span>
            <h3 class="font-['Space_Grotesk'] font-black text-xl text-[#1b1b1c] uppercase mb-3">Commercial</h3>
            <p class="text-[#564241] text-sm font-['Inter']">Commercial plumbing for Lincoln University, research facilities, and business properties.</p>
          </div>
        </div>
      </div>
    </section>
    
    <FAQ 
      items={faqItems}
      title="Lincoln Plumbing Questions"
      subtitle="Frequently asked questions from our Lincoln customers"
    />
    
    <section class="py-20 lg:py-28 bg-[#CD5C5C] mt-0">
      <div class="max-w-4xl mx-auto px-8 text-center">
        <h2 class="font-['Space_Grotesk'] font-black text-white text-4xl lg:text-5xl mb-6 uppercase tracking-tight">
          Need Plumbing in Lincoln?
        </h2>
        <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto font-['Inter']">
          Our licensed Lincoln plumbers are available for residential, rural, and commercial work. Same-day response available.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/contact/" class="btn-inverse group/btn">
            <span>Get a Free Quote</span>
            <span class="material-symbols-outlined transition-transform group-hover/btn:translate-x-1">arrow_forward</span>
          </a>
          <a href="tel:0800127665" class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest text-sm hover:bg-white/20 transition-colors border border-white/30">
            <span class="material-symbols-outlined">phone</span>
            <span>0800 1 BROOK</span>
          </a>
        </div>
      </div>
    </section>
    
  </main>
  
  <Footer />
</Layout>
