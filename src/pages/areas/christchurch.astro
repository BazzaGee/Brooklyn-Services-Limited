---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import FAQ from '../../components/ui/FAQ.astro';

const title = "Plumber in Christchurch | Brooklyn Services - 24/7 Emergency Plumbing";
const description = "Licensed plumber in Christchurch offering 24/7 emergency plumbing, drainage, leak detection & utility locating. No after-hours call-out fee. Call 0800 1 BROOK.";
const keywords = ["plumber Christchurch", "emergency plumber Christchurch", "drainlayer Christchurch", "leak detection Christchurch", "plumbing services Christchurch CBD"];

const faqItems = [
  {
    question: "How quickly can you respond to a plumbing emergency in Christchurch CBD?",
    answer: "We offer 24/7 emergency response across Christchurch CBD and all suburbs. Our rapid response team can typically arrive within 30-60 minutes for critical emergencies. Call 0800 1 BROOK for immediate assistance — and remember, we don't charge after-hours call-out fees."
  },
  {
    question: "What Christchurch suburbs do you service?",
    answer: "We service all of Christchurch and surrounding areas including CBD, Hoon Hay, Cashmere, Halswell, Hei Hei, Wigram, Hornby, Riccarton, Papanui, Shirley, Sumner, New Brighton, and all surrounding suburbs. Our utility locating and leak detection services extend South Island-wide."
  },
  {
    question: "Do you service commercial properties in Christchurch?",
    answer: "Yes. We provide comprehensive plumbing and drainage services for commercial properties across Christchurch including offices, retail spaces, restaurants, schools, healthcare facilities, and industrial complexes. We're the preferred contractor for major Christchurch businesses including Summerset Villages and Ryman Healthcare."
  },
  {
    question: "Are you licensed to work in Christchurch City Council developments?",
    answer: "Yes. All our plumbers and drainlayers are fully licensed and compliant with Christchurch City Council requirements. We handle new installations, alterations, and compliance certifications for both residential and commercial developments across the city."
  }
];
---

<Layout title={title} description={description} keywords={keywords}>
  <div class="fixed inset-0 isometric-pattern pointer-events-none z-0"></div>
  
  <Header />
  
  <main class="relative z-10 space-y-0 px-4 pb-20 max-w-[1800px] mx-auto">
    
    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 min-h-[500px]">
      <div class="md:col-span-7 bg-[#1b1b1c] p-12 lg:p-20 flex flex-col justify-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[#CD5C5C]/20 to-transparent"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-6 mb-8">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Service Area</span>
          </div>
          <h1 class="font-['Space_Grotesk'] font-black text-5xl lg:text-7xl text-white tracking-tighter leading-[0.9] uppercase mb-6">
            Christchurch<br/><span class="text-[#CD5C5C]">Plumbing</span>
          </h1>
          <p class="text-white/70 text-xl max-w-xl leading-relaxed font-light font-['Inter']">
            Licensed plumbers and drainlayers serving Christchurch CBD and all suburbs. 24/7 emergency response with no after-hours call-out fee.
          </p>
          <div class="mt-10 flex gap-4">
            <a href="/contact/" class="btn-actuator">
              <span>Request Service</span>
            </a>
            <a href="tel:0800127665" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest text-xs hover:bg-white/20 transition-colors border border-white/30">
              <span class="material-symbols-outlined">phone</span>
              <span>0800 1 BROOK</span>
            </a>
          </div>
        </div>
      </div>
      <div class="md:col-span-5 relative overflow-hidden bg-[#CD5C5C] tetris-module">
        <img 
          class="absolute inset-0 w-full h-full object-cover opacity-40 grayscale"
          src="/images/services/plumbing/commercial-maintenance-1.jpeg" 
          alt="Plumbing services in Christchurch"
        />
        <div class="absolute inset-0 bg-gradient-to-tl from-[#CD5C5C] to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8">
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white/10 p-6 skew-block">
              <div class="skew-block-content">
                <div class="font-['Space_Grotesk'] font-black text-3xl text-white">24/7</div>
                <div class="text-white/80 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">Response</div>
              </div>
            </div>
            <div class="bg-white p-6 skew-block">
              <div class="skew-block-content">
                <div class="font-['Space_Grotesk'] font-black text-3xl text-[#CD5C5C]">$0</div>
                <div class="text-[#1b1b1c]/70 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">After-Hours Fee</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Breadcrumbs -->
    <section class="px-4 -mt-4">
      <div class="bg-[#1b1b1c] px-6 py-4">
        <Breadcrumbs items={[{ label: 'Areas', href: '/areas/' }, { label: 'Christchurch' }]} />
      </div>
    </section>
    
    <section class="grid grid-cols-1 md:grid-cols-2 gap-0 mt-8">
      <div class="bg-[#f6f3f2] p-12 lg:p-16 border-r border-[#CD5C5C]/10 group hover:bg-white transition-colors">
        <span class="material-symbols-outlined text-[#CD5C5C] text-5xl mb-6 block">plumbing</span>
        <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black mb-4 block">Residential</span>
        <h2 class="font-['Space_Grotesk'] font-black text-2xl text-[#1b1b1c] uppercase mb-4">Christchurch Home Plumbing</h2>
        <p class="text-[#564241] font-['Inter'] leading-relaxed mb-6">
          Full residential plumbing services across Christchurch suburbs. From emergency repairs to new installations, our licensed plumbers handle everything from tap repairs to complete bathroom renovations.
        </p>
        <ul class="space-y-2 text-sm text-[#564241]">
          <li class="flex items-center gap-2"><span class="material-symbols-outlined text-[#CD5C5C] text-sm">check</span> Hot water cylinder replacement</li>
          <li class="flex items-center gap-2"><span class="material-symbols-outlined text-[#CD5C5C] text-sm">check</span> Burst pipe repairs</li>
          <li class="flex items-center gap-2"><span class="material-symbols-outlined text-[#CD5C5C] text-sm">check</span> Bathroom & kitchen plumbing</li>
          <li class="flex items-center gap-2"><span class="material-symbols-outlined text-[#CD5C5C] text-sm">check</span> New build plumbing</li>
          <li class="flex items-center gap-2"><span class="material-symbols-outlined text-[#CD5C5C] text-sm">check</span> Leak detection</li>
        </ul>
      </div>
      
      <div class="bg-[#1b1b1c] p-12 lg:p-16 group">
        <span class="material-symbols-outlined text-[#CD5C5C] text-5xl mb-6 block">construction</span>
        <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black mb-4 block">Commercial</span>
        <h2 class="font-['Space_Grotesk'] font-black text-2xl text-white uppercase mb-4">Christchurch Commercial Plumbing</h2>
        <p class="text-white/70 font-['Inter'] leading-relaxed mb-6">
          Comprehensive commercial plumbing and drainage for Christchurch businesses. We service offices, retail, hospitality, education, and healthcare facilities across the city.
        </p>
        <ul class="space-y-2 text-sm text-white/70">
          <li class="flex items-center gap-2"><span class="material-symbols-outlined text-[#CD5C5C] text-sm">check</span> Commercial fit-outs</li>
          <li class="flex items-center gap-2"><span class="material-symbols-outlined text-[#CD5C5C] text-sm">check</span> Maintenance contracts</li>
          <li class="flex items-center gap-2"><span class="material-symbols-outlined text-[#CD5C5C] text-sm">check</span> Emergency repairs</li>
          <li class="flex items-center gap-2"><span class="material-symbols-outlined text-[#CD5C5C] text-sm">check</span> Compliance inspections</li>
          <li class="flex items-center gap-2"><span class="material-symbols-outlined text-[#CD5C5C] text-sm">check</span> Large-scale projects</li>
        </ul>
      </div>
    </section>
    
    <section class="py-20 lg:py-28 bg-[#e5e2e1] mt-0">
      <div class="max-w-6xl mx-auto px-8">
        <div class="text-center mb-12">
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Coverage</span>
          <h2 class="font-['Space_Grotesk'] font-black text-4xl text-[#1b1b1c] uppercase mt-4 tracking-tight">
            Christchurch Suburbs We Service
          </h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {[
            "Christchurch CBD", "Hoon Hay", "Cashmere", "Halswell", "Hei Hei", "Wigram",
            "Hornby", "Riccarton", "Papanui", "Shirley", "Sumner", "New Brighton",
            "Bishopdale", "Northlands", "Casebrook", "Brynley Estate", "Phillipstown",
            "Avonhead", "Ilam", "Merivale", "Fendalton", "St Albans", "Sydenham",
            "Addington", "Woolston", "Sockburn", "Yaldhurst", "Avondale"
          ].map((suburb) => (
            <div class="bg-white p-4 group hover:bg-[#CD5C5C] transition-colors">
              <span class="font-['Space_Grotesk'] font-bold text-[#1b1b1c] uppercase text-xs tracking-wider group-hover:text-white">{suburb}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <FAQ 
      items={faqItems}
      title="Christchurch Plumbing Questions"
      subtitle="Frequently asked questions from our Christchurch customers"
    />
    
    <section class="py-20 lg:py-28 bg-[#CD5C5C] mt-0">
      <div class="max-w-4xl mx-auto px-8 text-center">
        <h2 class="font-['Space_Grotesk'] font-black text-white text-4xl lg:text-5xl mb-6 uppercase tracking-tight">
          Need a Plumber in Christchurch?
        </h2>
        <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto font-['Inter']">
          Our licensed Christchurch plumbers are available 24/7 for emergencies. No after-hours call-out fee.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/contact/" class="btn-inverse group/btn">
            <span>Get a Free Quote</span>
            <span class="material-symbols-outlined transition-transform group-hover/btn:translate-x-1">arrow_forward</span>
          </a>
          <a href="tel:0800127665" class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest text-sm hover:bg-white/20 transition-colors border border-white/30">
            <span class="material-symbols-outlined">phone</span>
            <span>0800 1 BROOK</span>
          </a>
        </div>
      </div>
    </section>
    
  </main>
  
  <Footer />
</Layout>
