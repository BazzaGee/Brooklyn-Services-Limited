---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import FAQ from '../../components/ui/FAQ.astro';

const title = "Plumber in Rolleston | Brooklyn Services - Plumbing & Drainage Selwyn";
const description = "Licensed plumber in Rolleston serving Selwyn District. Emergency plumbing, drainage, hot water systems. No after-hours call-out fee. Call 0800 1 BROOK.";
const keywords = ["plumber Rolleston", "plumber Selwyn", "drainlayer Rolleston", "plumbing Rolleston", "emergency plumber Selwyn District"];

const faqItems = [
  {
    question: "Do you service Rolleston and the Selwyn District?",
    answer: "Yes. We provide full plumbing and drainage services to Rolleston and the surrounding Selwyn District. Our team responds quickly to Rolleston for both emergency and scheduled work including new subdivisions, residential plumbing, and commercial projects."
  },
  {
    question: "Can you handle new build plumbing in Rolleston subdivisions?",
    answer: "Absolutely. Rolleston is one of Canterbury's fastest-growing areas with numerous new subdivisions. We have extensive experience with new build plumbing, drainage systems, water mains, and compliance certifications for new residential and commercial developments in Rolleston."
  },
  {
    question: "How quickly can you respond to Rolleston?",
    answer: "We offer rapid response to Rolleston from our Christchurch base. Most emergency calls receive same-day service. For scheduled work, we can typically attend within 24-48 hours. Call 0800 1 BROOK to discuss your Rolleston plumbing requirements."
  }
];
---

<Layout title={title} description={description} keywords={keywords}>
  <div class="fixed inset-0 isometric-pattern pointer-events-none z-0"></div>
  
  <Header />
  
  <main class="relative z-10 space-y-0 px-4 pb-20 max-w-[1800px] mx-auto">
    
    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 min-h-[500px]">
      <div class="md:col-span-7 bg-[#1b1b1c] p-12 lg:p-20 flex flex-col justify-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[#CD5C5C]/20 to-transparent"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-6 mb-8">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Service Area</span>
          </div>
          <h1 class="font-['Space_Grotesk'] font-black text-5xl lg:text-7xl text-white tracking-tighter leading-[0.9] uppercase mb-6">
            Rolleston<br/><span class="text-[#CD5C5C]">Plumbing</span>
          </h1>
          <p class="text-white/70 text-xl max-w-xl leading-relaxed font-light font-['Inter']">
            Licensed plumbers serving Rolleston and the Selwyn District. New builds, emergency repairs, and commercial plumbing.
          </p>
          <div class="mt-10 flex gap-4">
            <a href="/contact/" class="btn-actuator">
              <span>Request Service</span>
            </a>
            <a href="tel:0800127665" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest text-xs hover:bg-white/20 transition-colors border border-white/30">
              <span class="material-symbols-outlined">phone</span>
              <span>0800 1 BROOK</span>
            </a>
          </div>
        </div>
      </div>
      <div class="md:col-span-5 bg-[#CD5C5C] p-12 lg:p-16 flex flex-col justify-center tetris-module-alt">
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white/10 p-6 skew-block">
            <div class="skew-block-content">
              <div class="font-['Space_Grotesk'] font-black text-3xl text-white">Same Day</div>
              <div class="text-white/80 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">Response</div>
            </div>
          </div>
          <div class="bg-white p-6 skew-block">
            <div class="skew-block-content">
              <div class="font-['Space_Grotesk'] font-black text-3xl text-[#CD5C5C]">$0</div>
              <div class="text-[#1b1b1c]/70 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">After-Hours Fee</div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <section class="px-4 -mt-4">
      <div class="bg-[#1b1b1c] px-6 py-4">
        <Breadcrumbs items={[{ label: 'Areas', href: '/areas/' }, { label: 'Rolleston' }]} />
      </div>
    </section>
    
    <section class="py-20 lg:py-28 bg-[#f6f3f2] mt-8">
      <div class="max-w-6xl mx-auto px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <div>
            <h2 class="font-['Space_Grotesk'] font-black text-3xl text-[#1b1b1c] uppercase mb-6 tracking-tight">
              Rolleston Plumbing Services
            </h2>
            <p class="text-[#564241] text-lg leading-relaxed mb-6 font-['Inter']">
              As Rolleston continues to grow, we provide comprehensive plumbing and drainage services for new subdivisions, established homes, and commercial properties throughout the Selwyn District.
            </p>
            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
                <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
                New build plumbing & drainage
              </li>
              <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
                <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
                Hot water cylinder replacement
              </li>
              <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
                <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
                Emergency plumbing repairs
              </li>
              <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
                <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
                Bathroom & kitchen renovations
              </li>
              <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
                <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
                Blocked drain clearing
              </li>
              <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
                <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
                Commercial plumbing
              </li>
            </ul>
          </div>
          <div class="bg-[#1b1b1c] p-12 lg:p-16">
            <h3 class="font-['Space_Grotesk'] font-black text-2xl text-white uppercase mb-6 tracking-tight">
              Why Choose Brooklyn Services in Rolleston?
            </h3>
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-[#CD5C5C] text-2xl">speed</span>
                <div>
                  <h4 class="font-['Space_Grotesk'] font-bold text-white uppercase text-sm">Fast Response</h4>
                  <p class="text-white/70 text-sm font-['Inter']">Same-day service available across Rolleston and Selwyn</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-[#CD5C5C] text-2xl">savings</span>
                <div>
                  <h4 class="font-['Space_Grotesk'] font-bold text-white uppercase text-sm">No After-Hours Fee</h4>
                  <p class="text-white/70 text-sm font-['Inter']">Emergency calls cost the same as business hours</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-[#CD5C5C] text-2xl">verified</span>
                <div>
                  <h4 class="font-['Space_Grotesk'] font-bold text-white uppercase text-sm">Fully Licensed</h4>
                  <p class="text-white/70 text-sm font-['Inter']">All plumbers hold current NZ licenses and certifications</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <FAQ 
      items={faqItems}
      title="Rolleston Plumbing Questions"
      subtitle="Frequently asked questions from our Rolleston customers"
    />
    
    <section class="py-20 lg:py-28 bg-[#CD5C5C] mt-0">
      <div class="max-w-4xl mx-auto px-8 text-center">
        <h2 class="font-['Space_Grotesk'] font-black text-white text-4xl lg:text-5xl mb-6 uppercase tracking-tight">
          Need Plumbing in Rolleston?
        </h2>
        <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto font-['Inter']">
          Our licensed Rolleston plumbers are available for emergency and scheduled work. Same-day response available.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/contact/" class="btn-inverse group/btn">
            <span>Get a Free Quote</span>
            <span class="material-symbols-outlined transition-transform group-hover/btn:translate-x-1">arrow_forward</span>
          </a>
          <a href="tel:0800127665" class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest text-sm hover:bg-white/20 transition-colors border border-white/30">
            <span class="material-symbols-outlined">phone</span>
            <span>0800 1 BROOK</span>
          </a>
        </div>
      </div>
    </section>
    
  </main>
  
  <Footer />
</Layout>
