---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';

const title = "Resources | Brooklyn Services - Infrastructure Intelligence";
const description = "Expert plumbing, drainage, and infrastructure maintenance resources from Brooklyn Services. Technical guides and protocols for Christchurch & Canterbury.";

const posts = [
  {
    slug: 'signs-of-a-water-leak',
    title: '7 Warning Signs You Have a Hidden Water Leak in Your Home',
    description: 'Learn the 7 warning signs of a hidden water leak in your Christchurch home. From unexplained water bills to musty odors.',
    tags: ['leak-detection', 'plumbing-tips'],
    publishDate: '2026-04-19'
  },
  {
    slug: 'preventing-blocked-drains',
    title: 'How to Prevent Blocked Drains: 10 Essential Tips for Christchurch Homes',
    description: 'Prevent blocked drains with these 10 essential tips from Brooklyn Services. Learn what causes drain blockages.',
    tags: ['drainage', 'maintenance-tips'],
    publishDate: '2026-04-19'
  },
  {
    slug: 'choosing-hot-water-system',
    title: 'How to Choose the Right Hot Water System for Your Christchurch Home',
    description: 'Confused about hot water systems? Our Christchurch plumbers explain the pros and cons of cylinders vs continuous flow.',
    tags: ['hot-water', 'plumbing'],
    publishDate: '2026-04-19'
  },
  {
    slug: 'rinnai-vs-rheem-hot-water',
    title: 'Rinnai vs Rheem: Which Hot Water System is Best for Your Home?',
    description: 'Compare Rinnai and Rheem hot water systems. Learn about continuous flow vs storage systems and efficiency ratings.',
    tags: ['hot-water', 'product-comparison'],
    publishDate: '2026-04-19'
  },
  {
    slug: 'plumbing-maintenance-checklist',
    title: 'Annual Plumbing Maintenance Checklist for Christchurch Homeowners',
    description: 'Keep your plumbing in top condition with our annual maintenance checklist. Prevent costly repairs with regular maintenance.',
    tags: ['maintenance', 'plumbing-tips'],
    publishDate: '2026-04-19'
  }
];
---

<Layout title={title} description={description}>
  <div class="fixed inset-0 isometric-pattern pointer-events-none z-0"></div>
  
  <Header />
  
  <main class="relative z-10">
    <!-- Hero -->
    <section class="py-20 lg:py-28 bg-[#f6f3f2] relative overflow-hidden">
      <div class="max-w-[1800px] mx-auto px-8">
        <div class="text-center max-w-3xl mx-auto">
          <div class="flex items-center justify-center gap-6 mb-8">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Information Resources</span>
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          </div>
          <h1 class="font-['Space_Grotesk'] font-black text-5xl lg:text-6xl text-[#1b1b1c] uppercase mb-6 tracking-tight">
            Infrastructure<br/><span class="text-[#CD5C5C]">Intelligence</span>
          </h1>
          <p class="text-xl text-[#564241] leading-relaxed font-['Inter']">
            Technical protocols and maintenance guides from our licensed infrastructure specialists.
          </p>
        </div>
      </div>
    </section>

    <!-- Blog Grid -->
    <section class="py-20 lg:py-28 max-w-[1800px] mx-auto px-8">
      {posts.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <article class="bg-[#f0eded] group hover:bg-white transition-all duration-300 hover:shadow-ambient">
              <a href={`/blog/${post.slug}/`} class="block">
                <div class="aspect-video bg-[#1b1b1c] flex items-center justify-center overflow-hidden relative">
                  <span class="material-symbols-outlined text-6xl text-[#CD5C5C]/40">article</span>
                  <div class="absolute inset-0 bg-[#CD5C5C]/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                </div>
                <div class="p-6">
                  <div class="flex flex-wrap gap-2 mb-4">
                    {post.tags?.slice(0, 2).map((tag) => (
                      <span class="px-3 py-1 bg-[#CD5C5C]/10 text-[#CD5C5C] text-xs font-['Space_Grotesk'] uppercase tracking-wider font-bold">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <h2 class="font-['Space_Grotesk'] font-bold text-xl text-[#1b1b1c] mb-3 group-hover:text-[#CD5C5C] transition-colors line-clamp-2">
                    {post.title}
                  </h2>
                  <p class="text-[#564241] text-sm mb-4 line-clamp-3 font-['Inter']">
                    {post.description}
                  </p>
                  <div class="flex items-center justify-between pt-4 border-t border-[#CD5C5C]/10">
                    <time class="text-xs text-[#564241] font-['Space_Grotesk'] uppercase tracking-wider">
                      {new Date(post.publishDate).toLocaleDateString('en-NZ', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                    <span class="material-symbols-outlined text-[#CD5C5C] group-hover:translate-x-1 transition-transform">
                      arrow_forward
                    </span>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <span class="material-symbols-outlined text-6xl text-[#564241]/40 mb-4">article</span>
          <h2 class="font-['Space_Grotesk'] font-bold text-xl text-[#1b1b1c] uppercase mb-2">No resources available</h2>
          <p class="text-[#564241]">Check back soon for technical documentation and protocols.</p>
        </div>
      )}
    </section>

    <!-- CTA -->
    <section class="py-20 lg:py-28 bg-[#f6f3f2]">
      <div class="max-w-4xl mx-auto px-8 text-center">
        <h2 class="font-['Space_Grotesk'] font-black text-[#1b1b1c] text-3xl lg:text-4xl mb-4 uppercase tracking-tight">
          Need Professional Assistance?
        </h2>
        <p class="text-[#564241] text-lg mb-8 max-w-2xl mx-auto font-['Inter']">
          Our licensed infrastructure specialists are ready to help with all your plumbing, drainage, and detection requirements.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/contact/" class="btn-actuator">
            <span>Initiate Consultation</span>
          </a>
          <a href="tel:0800127665" class="btn-secondary">
            <span>0800 1 BROOK</span>
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
