---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';

export async function getStaticPaths() {
  const posts = await Astro.glob('../../../content/blog/*.md');
  return posts.map((post) => ({
    params: { slug: post.frontmatter.slug || post.file.split('/').pop()?.replace('.md', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = post;

const {
  title,
  description = 'Expert infrastructure intelligence from Brooklyn Services Limited',
  keywords = [],
  author = 'Brooklyn Services Limited',
  publishDate,
  modifiedDate,
  tags = [],
} = post.frontmatter;

const formattedDate = publishDate
  ? new Date(publishDate).toLocaleDateString('en-NZ', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Organization",
    "name": author,
    "url": "https://brooklynservices.co.nz"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Brooklyn Services Limited",
    "url": "https://brooklynservices.co.nz",
    "logo": {
      "@type": "ImageObject",
      "url": "https://brooklynservices.co.nz/images/logo.png"
    }
  },
  "datePublished": publishDate,
  "dateModified": modifiedDate || publishDate,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://brooklynservices.co.nz/blog/${Astro.params.slug}/`
  }
};

const displayTags = tags.length > 0 ? tags.slice(0, 4) : [];
---

<Layout
  title={`${title} | Brooklyn Services`}
  description={description}
  keywords={keywords}
  structuredData={articleSchema}
>
  <div class="fixed inset-0 isometric-pattern pointer-events-none z-0"></div>

  <Header />

  <main class="relative z-10">
    <article class="py-20 lg:py-28">
      <div class="max-w-3xl mx-auto px-8">

        <nav class="flex items-center gap-2 text-sm text-[#564241] mb-8 font-['Inter']">
          <a href="/" class="hover:text-[#CD5C5C] transition-colors">Home</a>
          <span>/</span>
          <a href="/blog/" class="hover:text-[#CD5C5C] transition-colors">Resources</a>
          <span>/</span>
          <span class="text-[#1b1b1c] font-medium line-clamp-1">{title}</span>
        </nav>

        <header class="mb-12">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black">Technical Brief</span>
          </div>
          <h1 class="font-['Space_Grotesk'] font-black text-3xl lg:text-4xl text-[#1b1b1c] mb-4 uppercase tracking-tight leading-tight">
            {title}
          </h1>
          <div class="flex flex-wrap items-center gap-4 text-sm text-[#564241] font-['Inter']">
            <span>{author}</span>
            {formattedDate && (
              <>
                <span class="text-[#CD5C5C]">&bull;</span>
                <time class="font-['Space_Grotesk'] uppercase tracking-wider text-xs">{formattedDate}</time>
              </>
            )}
          </div>
          {displayTags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-6">
              {displayTags.map((tag: string) => (
                <span class="px-3 py-1 bg-[#CD5C5C]/10 text-[#CD5C5C] text-xs font-['Space_Grotesk'] uppercase tracking-wider font-bold">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <div class="prose-container">
          <Content />
        </div>

        <div class="mt-12 flex items-center gap-2 text-[#564241]">
          <a href="/blog/" class="inline-flex items-center gap-2 text-[#CD5C5C] font-['Space_Grotesk'] font-bold uppercase tracking-wider text-sm hover:underline">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            Back to all resources
          </a>
        </div>

        <div class="mt-16 p-8 bg-[#f6f3f2] border-l-4 border-[#CD5C5C]">
          <h3 class="font-['Space_Grotesk'] font-black text-xl text-[#1b1b1c] uppercase mb-2">Require Professional Support?</h3>
          <p class="text-[#564241] mb-6 font-['Inter']">
            Contact Brooklyn Services for expert infrastructure solutions in Christchurch and Canterbury.
          </p>
          <a href="/contact/" class="btn-actuator">
            <span>Initiate Consultation</span>
          </a>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
