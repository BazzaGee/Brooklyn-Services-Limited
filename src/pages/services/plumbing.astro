---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Gallery from '../../components/ui/Gallery.astro';
import HorizontalScroll from '../../components/ui/HorizontalScroll.astro';

const title = "Plumbing Dynamics | Brooklyn Services - System 01";
const description = "Precision hydraulic engineering for commercial and residential infrastructure. Licensed plumbers serving Christchurch & Canterbury. Call 0800 1 BROOK.";

const galleryImages = [
  { src: '/images/services/plumbing/water-filter-install.jpeg', alt: 'Whole house water filter installation', caption: 'Water Filter Install' },
  { src: '/images/services/plumbing/hot-water-cylinder-replacement.jpeg', alt: 'Hot water cylinder replacement', caption: 'Cylinder Replacement' },
  { src: '/images/services/plumbing/commercial-boiler-replacement.jpg', alt: 'Commercial hot water boiler replacement', caption: 'Commercial Boiler' },
  { src: '/images/services/plumbing/commercial-maintenance-1.jpeg', alt: 'Commercial plumbing maintenance', caption: 'Commercial Maintenance' },
  { src: '/images/services/plumbing/commercial-maintenance-2.jpeg', alt: 'Commercial plumbing maintenance in progress', caption: 'Maintenance Work' },
  { src: '/images/services/plumbing/rural-plumbing-repairs.jpg', alt: 'Rural plumbing repairs', caption: 'Rural Repairs' },
  { src: '/images/services/plumbing/valve-replacement.jpg', alt: 'Replacing rusty butterfly valves', caption: 'Valve Replacement' },
  { src: '/images/services/plumbing/commercial-plumbing.jpg', alt: 'Commercial plumbing maintenance', caption: 'Commercial Plumbing' },
  { src: '/images/services/plumbing/historical-work-1.jpeg', alt: 'Plumbing work project', caption: 'Project Work' },
  { src: '/images/services/plumbing/historical-work-2.jpeg', alt: 'Plumbing installation', caption: 'Installation' },
  { src: '/images/services/plumbing/historical-work-3.jpeg', alt: 'Plumbing service', caption: 'Service Work' },
];

const advantages = [
  { icon: "verified", title: "Licensed & Certified", desc: "Fully licensed plumbers with current certifications and ongoing technical training.", color: "#f6f3f2" },
  { icon: "schedule", title: "Same-Day Service", desc: "Emergency response available with fast turnaround times across Canterbury.", color: "#1b1b1c" },
  { icon: "savings", title: "No After-Hours Fee", desc: "Fair pricing always. We don't charge extra for emergency call-outs.", color: "#CD5C5C" },
  { icon: "handshake", title: "Rinnai Authorized", desc: "Authorized service centre for Rinnai across Canterbury. Supply, install, and service.", color: "#f6f3f2" },
  { icon: "emergency", title: "24/7 Emergency", desc: "Burst pipes, blocked drains, no hot water — we respond around the clock.", color: "#1b1b1c" },
  { icon: "build", title: "New Build Specialist", desc: "Full plumbing systems for new residential and commercial construction projects.", color: "#f6f3f2" },
];
---

<Layout title={title} description={description}>
  <div class="fixed inset-0 isometric-pattern pointer-events-none z-0"></div>
  
  <Header />
  
  <main class="relative z-10 space-y-0 px-4 pb-20 max-w-[1800px] mx-auto">
    
    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 min-h-[600px]">
      <div class="md:col-span-8 bg-[#f6f3f2] p-12 lg:p-20 flex flex-col justify-center relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-[#CD5C5C]/5 -mr-32 -mt-32 rotate-45"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-6 mb-8">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">System 01</span>
          </div>
          <h1 class="font-['Space_Grotesk'] font-black text-5xl lg:text-7xl text-[#1b1b1c] tracking-tighter leading-[0.9] uppercase mb-6">
            Plumbing<br/><span class="text-[#CD5C5C]">Dynamics</span>
          </h1>
          <p class="text-[#564241] text-xl max-w-xl leading-relaxed font-light font-['Inter']">
            Expert licensed plumbers with over 50 years combined experience delivering precision hydraulic engineering for commercial and residential infrastructure across Christchurch and Canterbury.
          </p>
          <div class="mt-10 flex gap-4">
            <a href="/contact/" class="btn-actuator">
              <span>Request Assessment</span>
            </a>
          </div>
        </div>
      </div>
      <div class="md:col-span-4 bg-[#CD5C5C] p-12 lg:p-16 flex flex-col justify-end tetris-module-alt relative">
        <div class="absolute inset-0 bg-gradient-to-br from-[#CD5C5C] to-[#9f393b]"></div>
        <div class="relative z-10">
          <span class="material-symbols-outlined text-white text-7xl mb-6 block">plumbing</span>
          <h3 class="font-['Space_Grotesk'] font-black text-2xl text-white uppercase tracking-tight mb-4">Licensed Specialists</h3>
          <p class="text-white/80 font-['Inter']">Fully certified plumbers with 50+ years combined experience across Canterbury.</p>
        </div>
      </div>
    </section>
    
    <section class="grid grid-cols-1 md:grid-cols-2 gap-0 mt-8">
      <div class="bg-[#1b1b1c] p-12 lg:p-16 group">
        <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black mb-4 block">Residential</span>
        <h2 class="font-['Space_Grotesk'] font-black text-3xl text-white uppercase mb-6">Home Systems</h2>
        <ul class="space-y-4">
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            New installation & renovations
          </li>
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            Hot water systems & cylinders
          </li>
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            Tap & fixture repairs
          </li>
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            Pipe repairs & replacements
          </li>
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            Bathroom & kitchen plumbing
          </li>
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            Water mains installation
          </li>
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            Spouting & guttering
          </li>
        </ul>
      </div>
      
      <div class="bg-[#e5e2e1] p-12 lg:p-16 group">
        <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black mb-4 block">Commercial</span>
        <h2 class="font-['Space_Grotesk'] font-black text-3xl text-[#1b1b1c] uppercase mb-6">Business Infrastructure</h2>
        <ul class="space-y-4">
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            Commercial fit-outs
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            Industrial plumbing systems
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            Maintenance contracts
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            Emergency repairs
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            Compliance inspections
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            Complex problem solving
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="material-symbols-outlined text-[#CD5C5C]">check_circle</span>
            Large-scale projects
          </li>
        </ul>
      </div>
    </section>
    
    <section class="py-20 lg:py-28 bg-[#f6f3f2] mt-8">
      <div class="max-w-6xl mx-auto px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="relative h-[400px] overflow-hidden skew-block modular-shadow">
            <img 
              class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
              src="/images/services/plumbing/hot-water-cylinder-replacement.jpeg" 
              alt="Hot water cylinder replacement by Brooklyn Services"
            />
            <div class="absolute inset-0 bg-[#CD5C5C]/10"></div>
          </div>
          <div>
            <div class="flex items-center gap-6 mb-8">
              <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
              <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Authorized Agent</span>
            </div>
            <h2 class="font-['Space_Grotesk'] font-black text-4xl text-[#1b1b1c] uppercase mb-6 tracking-tight">
              Hot Water Systems
            </h2>
            <p class="text-[#564241] text-lg leading-relaxed mb-6 font-['Inter']">
              As authorized agents for Rinnai and Electrolux, we supply, install, and service a complete range of hot water solutions. 
              From continuous flow gas systems to large commercial cylinders, our technicians ensure optimal performance and efficiency.
            </p>
            <p class="text-[#564241] text-lg leading-relaxed mb-6 font-['Inter']">
              We also service boiling water systems including Rinnai Boil & Brew, Rheem Lazer, and classic Kiwi Zip instant boiling water units.
              Free quotes available on repair or replacement options.
            </p>
            <div class="flex flex-wrap gap-3 mb-8">
              <span class="px-4 py-2 bg-white text-[#564241] font-['Space_Grotesk'] text-xs uppercase tracking-wider font-bold">Rinnai</span>
              <span class="px-4 py-2 bg-white text-[#564241] font-['Space_Grotesk'] text-xs uppercase tracking-wider font-bold">Electrolux</span>
              <span class="px-4 py-2 bg-white text-[#564241] font-['Space_Grotesk'] text-xs uppercase tracking-wider font-bold">Rheem</span>
              <span class="px-4 py-2 bg-white text-[#564241] font-['Space_Grotesk'] text-xs uppercase tracking-wider font-bold">Gas & Electric</span>
            </div>
            <div class="flex items-center gap-4">
              <img src="/images/rinnai-badge.png" alt="Rinnai Authorized Service Centre" class="h-12 w-auto" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28 bg-[#e5e2e1] mt-0">
      <div class="max-w-6xl mx-auto px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="flex items-center gap-6 mb-8">
              <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
              <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Quality</span>
            </div>
            <h2 class="font-['Space_Grotesk'] font-black text-4xl text-[#1b1b1c] uppercase mb-6 tracking-tight">
              Water Filtration & Quality
            </h2>
            <p class="text-[#564241] text-lg leading-relaxed mb-6 font-['Inter']">
              Clean, pure water for your home or business. We install a full range of water filtration systems including whole house filters, inline filters, under bench units, UV sterilisation, and carbon filtration systems.
            </p>
            <p class="text-[#564241] text-lg leading-relaxed mb-6 font-['Inter']">
              We recommend quality products from Mico and Reece — built to last, efficient, energy-saving and sustainable.
            </p>
            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
                <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
                Whole house water filters
              </li>
              <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
                <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
                Inline main water filters
              </li>
              <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
                <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
                UV & carbon filtration
              </li>
              <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
                <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
                Backflow prevention devices
              </li>
            </ul>
          </div>
          <div class="relative h-[400px] bg-[#1b1b1c] overflow-hidden skew-block modular-shadow">
            <img 
              class="absolute inset-0 w-full h-full object-cover opacity-60 grayscale group-hover:grayscale-0 transition-all duration-700"
              src="/images/services/plumbing/water-filter-install.jpeg" 
              alt="Whole house water filter installation"
            />
            <div class="absolute inset-0 bg-[#CD5C5C]/10"></div>
          </div>
        </div>
      </div>
    </section>
    
    <Gallery 
      images={galleryImages}
      title="Our Plumbing Work"
      subtitle="Recent projects showcasing our plumbing expertise across residential, commercial, and rural properties."
      columns={4}
      horizontal={true}
    />
    
    <section class="bg-[#f6f3f2] mt-0">
      <div class="max-w-[1800px] mx-auto px-8 pt-20 lg:pt-28 pb-4">
        <div class="text-center mb-12">
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Advantages</span>
          <h2 class="font-['Space_Grotesk'] font-black text-4xl text-[#1b1b1c] uppercase mt-4 tracking-tight">
            Why Brooklyn Services
          </h2>
        </div>
      </div>
      <HorizontalScroll bgColor="#f6f3f2">
        {advantages.map((adv) => (
          <div class="group hover:bg-white transition-colors" style={`min-width: 320px; max-width: 360px; background: ${adv.color}; padding: 2rem;`}>
            <div class="w-14 h-14 bg-[#CD5C5C]/10 mb-6 flex items-center justify-center skew-block group-hover:bg-[#CD5C5C] transition-colors">
              <span class="material-symbols-outlined text-3xl text-[#CD5C5C] group-hover:text-white skew-block-content transition-colors">{adv.icon}</span>
            </div>
            <h3 class={`font-['Space_Grotesk'] font-black text-xl uppercase mb-3 ${adv.color === '#CD5C5C' ? 'text-white' : 'text-[#1b1b1c]'}`}>{adv.title}</h3>
            <p class={`text-sm font-['Inter'] ${adv.color === '#CD5C5C' ? 'text-white/90' : adv.color === '#1b1b1c' ? 'text-white/70' : 'text-[#564241]'}`}>{adv.desc}</p>
          </div>
        ))}
      </HorizontalScroll>
    </section>
    
    <section class="py-20 lg:py-28 bg-[#CD5C5C] mt-0">
      <div class="max-w-4xl mx-auto px-8 text-center">
        <h2 class="font-['Space_Grotesk'] font-black text-white text-4xl lg:text-5xl mb-6 uppercase tracking-tight">
          Ready to Initiate?
        </h2>
        <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto font-['Inter']">
          Contact our plumbing specialists for assessments, quotes, or emergency response.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/contact/" class="btn-inverse group/btn">
            <span>Get a Free Quote</span>
            <span class="material-symbols-outlined transition-transform group-hover/btn:translate-x-1">arrow_forward</span>
          </a>
          <a href="tel:0800127665" class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest text-sm hover:bg-white/20 transition-colors border border-white/30">
            <span class="material-symbols-outlined">phone</span>
            <span>0800 1 BROOK</span>
          </a>
        </div>
      </div>
    </section>
    
  </main>
  
  <Footer />
</Layout>
