---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HorizontalScroll from '../../components/ui/HorizontalScroll.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';

const title = "Services | Brooklyn Services - Infrastructure Systems";
const description = "Complete infrastructure solutions: Plumbing, Drainage, Utility Locating & Leak Detection. Licensed specialists serving Christchurch & Canterbury. Call 0800 1 BROOK.";

const services = [
  {
    system: "System 01",
    title: "Plumbing",
    subtitle: "Dynamics",
    description: "Precision hydraulic engineering for commercial infrastructure. System-wide diagnostics and proactive maintenance protocols designed for longevity.",
    icon: "plumbing",
    href: "/services/plumbing/",
    features: ["Residential & Commercial", "Hot Water Systems", "Emergency Repairs", "Renovations"]
  },
  {
    system: "System 02",
    title: "Drainage",
    subtitle: "Logistics",
    description: "Topographical flow mapping and high-capacity drainage solutions for municipal scale projects and industrial complexes.",
    icon: "water_damage",
    href: "/services/drainage/",
    features: ["New Installations", "Blocked Drain Clearing", "CCTV Inspection", "Septic Systems"]
  },
  {
    system: "System 03",
    title: "Utility",
    subtitle: "Locating",
    description: "Sub-surface radar mapping (GPR) for risk mitigation during heavy infrastructure development and site preparation.",
    icon: "radar",
    href: "/services/utility-locating/",
    features: ["GPR Scanning", "Electromagnetic Locating", "Service Mapping", "Non-Destructive Testing"]
  },
  {
    system: "System 04",
    title: "Leak",
    subtitle: "Detection",
    description: "Non-invasive acoustic profiling and thermal imaging technologies to identify structural vulnerabilities before failure occurs.",
    icon: "search",
    href: "/services/leak-detection/",
    features: ["Acoustic Detection", "Thermal Imaging", "Slab Leaks", "Hidden Leaks"]
  }
];

const stats = [
  { value: "50+", label: "Years Combined Experience" },
  { value: "4", label: "Expert Systems" },
  { value: "1000+", label: "Projects Completed" },
  { value: "24/7", label: "Emergency Response" }
];

const capabilities = [
  { name: "Ground Penetrating Radar", tag: "GPR" },
  { name: "CCTV Drain Inspection", tag: "Video" },
  { name: "Acoustic Leak Detection", tag: "Geophone" },
  { name: "Thermal Imaging", tag: "Infrared" },
  { name: "Water Blaster Truck", tag: "High Pressure" },
  { name: "Electromagnetic Locating", tag: "Cable Trace" },
  { name: "Sonde Location", tag: "Depth Find" },
  { name: "Rinnai Authorized", tag: "Certified" },
  { name: "Electrolux Authorized", tag: "Certified" },
  { name: "Pressure Testing", tag: "Diagnostics" },
  { name: "Pipe Freezing", tag: "Non-Drain" },
  { name: "Gas Detection", tag: "Safety" },
];
---

<Layout title={title} description={description}>
  <div class="fixed inset-0 isometric-pattern pointer-events-none z-0"></div>
  
  <Header />
  
  <main class="relative z-10 space-y-0 pb-20 max-w-[1800px] mx-auto">
    
    <!-- Hero Section -->
    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 min-h-[600px]">
      <div class="md:col-span-8 bg-[#1b1b1c] p-12 lg:p-20 flex flex-col justify-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[#CD5C5C]/20 to-transparent"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-6 mb-8">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Systems Overview</span>
          </div>
          <h1 class="font-['Space_Grotesk'] font-black text-5xl lg:text-7xl text-white tracking-tighter leading-[0.9] uppercase mb-6">
            Infrastructure<br/><span class="text-[#CD5C5C]">Systems</span>
          </h1>
          <p class="text-white/70 text-xl max-w-xl leading-relaxed font-light font-['Inter']">
            Four specialized infrastructure divisions delivering precision-engineered solutions across Canterbury.
          </p>
        </div>
      </div>
      <div class="md:col-span-4 bg-[#CD5C5C] p-12 lg:p-16 flex flex-col justify-end tetris-module-alt relative">
        <div class="grid grid-cols-2 gap-4">
          {stats.map(stat => (
            <div class="bg-white/10 p-6 skew-block group hover:bg-white/20 transition-colors">
              <div class="skew-block-content">
                <div class="font-['Space_Grotesk'] font-black text-3xl text-white mb-1">{stat.value}</div>
                <div class="text-white/80 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">{stat.label}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Breadcrumbs -->
    <section class="px-4 -mt-4">
      <div class="bg-[#f6f3f2] px-6 py-4">
        <Breadcrumbs items={[{ label: 'Services' }]} />
      </div>
    </section>
    
    <!-- Services Grid -->
    <section class="px-4 mt-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
        {services.map((service, index) => (
          <a 
            href={service.href}
            class={`p-12 lg:p-16 group relative overflow-hidden transition-all duration-500 ${index % 2 === 0 ? 'bg-[#f6f3f2] hover:bg-white' : 'bg-[#1b1b1c]'} ${index < 2 ? 'border-b border-[#CD5C5C]/10' : ''} ${index % 2 === 0 ? 'border-r border-[#CD5C5C]/10' : ''}`}
          >
            <div class="relative z-10">
              <div class="flex items-center gap-6 mb-8">
                <div class={`w-16 h-1.5 skew-block ${index % 2 === 0 ? 'bg-[#CD5C5C]' : 'bg-[#CD5C5C]'}`}></div>
                <span class={`font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black ${index % 2 === 0 ? 'text-[#CD5C5C]' : 'text-[#CD5C5C]'}`}>
                  {service.system}
                </span>
              </div>
              
              <span class={`material-symbols-outlined text-6xl mb-6 block ${index % 2 === 0 ? 'text-[#CD5C5C]' : 'text-[#CD5C5C]'}`}>
                {service.icon}
              </span>
              
              <h2 class={`font-['Space_Grotesk'] font-black text-4xl lg:text-5xl uppercase mb-2 tracking-tight leading-none ${index % 2 === 0 ? 'text-[#1b1b1c]' : 'text-white'}`}>
                {service.title}<br/>
                <span class={`${index % 2 === 0 ? 'text-[#CD5C5C]/60' : 'text-[#CD5C5C]'}`}>{service.subtitle}</span>
              </h2>
              
              <p class={`text-lg leading-relaxed mb-8 font-['Inter'] ${index % 2 === 0 ? 'text-[#564241]' : 'text-white/70'}`}>
                {service.description}
              </p>
              
              <ul class="space-y-3 mb-8">
                {service.features.map(feature => (
                  <li class={`flex items-center gap-3 font-['Inter'] ${index % 2 === 0 ? 'text-[#564241]' : 'text-white/70'}`}>
                    <span class={`w-2 h-2 skew-block ${index % 2 === 0 ? 'bg-[#CD5C5C]' : 'bg-[#CD5C5C]'}`}></span>
                    {feature}
                  </li>
                ))}
              </ul>
              
              <div class={`inline-flex items-center gap-2 font-['Space_Grotesk'] font-bold uppercase tracking-wider text-sm group-hover:gap-4 transition-all ${index % 2 === 0 ? 'text-[#CD5C5C]' : 'text-[#CD5C5C]'}`}>
                <span>View System Details</span>
                <span class="material-symbols-outlined">arrow_forward</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
    
    <!-- Capabilities Strip -->
    <section class="bg-[#1b1b1c] mt-8">
      <div class="max-w-[1800px] mx-auto px-8 pt-16 lg:pt-20 pb-4">
        <div class="flex items-center gap-6 mb-6">
          <div class="w-12 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Capabilities</span>
        </div>
        <h2 class="font-['Space_Grotesk'] font-black text-3xl lg:text-4xl text-white uppercase tracking-tight">
          Technology & Equipment
        </h2>
      </div>
      <HorizontalScroll bgColor="#1b1b1c">
        {capabilities.map((item) => (
          <div class="bg-[#252525] p-6 group hover:bg-[#CD5C5C] transition-all duration-500 flex items-center gap-4" style="min-width: 260px; max-width: 300px;">
            <div class="flex-1">
              <h4 class="font-['Space_Grotesk'] font-black text-sm text-white uppercase tracking-wider group-hover:text-white">{item.name}</h4>
            </div>
            <span class="px-3 py-1 bg-[#CD5C5C]/20 group-hover:bg-white/20 text-[#CD5C5C] group-hover:text-[#CD5C5C] text-xs font-['Space_Grotesk'] uppercase tracking-wider font-bold flex-shrink-0">{item.tag}</span>
          </div>
        ))}
      </HorizontalScroll>
    </section>
    
    <!-- The Brooklyn Protocol -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-0 mt-8">
      <div class="bg-[#CD5C5C] p-12 lg:p-20 flex flex-col justify-center">
        <span class="font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black text-white/80 mb-4">Our Methodology</span>
        <h2 class="font-['Space_Grotesk'] font-black text-4xl lg:text-5xl text-white uppercase mb-6 tracking-tight">
          The Brooklyn<br/>Protocol
        </h2>
        <p class="text-white/90 text-lg leading-relaxed mb-10 font-['Inter']">
          Every project follows our three-phase protocol ensuring precision, efficiency, and minimal disruption to your operations.
        </p>
        
        <div class="space-y-8">
          <div class="flex gap-6 group">
            <div class="w-12 h-12 bg-white/20 flex items-center justify-center skew-block flex-shrink-0 group-hover:bg-white/30 transition-colors">
              <span class="material-symbols-outlined text-white text-xl skew-block-content">sensors</span>
            </div>
            <div>
              <h3 class="font-['Space_Grotesk'] font-black text-white uppercase tracking-wider mb-2">01 Detection</h3>
              <p class="text-white/80 font-['Inter']">Rapid assessment and diagnostic protocols</p>
            </div>
          </div>
          
          <div class="flex gap-6 group">
            <div class="w-12 h-12 bg-white/20 flex items-center justify-center skew-block flex-shrink-0 group-hover:bg-white/30 transition-colors">
              <span class="material-symbols-outlined text-white text-xl skew-block-content">analytics</span>
            </div>
            <div>
              <h3 class="font-['Space_Grotesk'] font-black text-white uppercase tracking-wider mb-2">02 Analysis</h3>
              <p class="text-white/80 font-['Inter']">Data-driven engineering recommendations</p>
            </div>
          </div>
          
          <div class="flex gap-6 group">
            <div class="w-12 h-12 bg-white/20 flex items-center justify-center skew-block flex-shrink-0 group-hover:bg-white/30 transition-colors">
              <span class="material-symbols-outlined text-white text-xl skew-block-content">construction</span>
            </div>
            <div>
              <h3 class="font-['Space_Grotesk'] font-black text-white uppercase tracking-wider mb-2">03 Execution</h3>
              <p class="text-white/80 font-['Inter']">Surgical precision implementation</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="relative min-h-[500px] overflow-hidden">
        <img 
          class="absolute inset-0 w-full h-full object-cover grayscale brightness-50"
          src="/images/drainage-work.jpg" 
          alt="Infrastructure Work"
        />
        <div class="absolute inset-0 bg-[#CD5C5C]/20"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-center text-white">
            <div class="font-['Space_Grotesk'] font-black text-8xl mb-4">4</div>
            <div class="text-xl uppercase tracking-[0.3em] font-['Space_Grotesk'] font-bold">Specialized Systems</div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- CTA Section -->
    <section class="py-20 lg:py-28 bg-[#CD5C5C] mt-8">
      <div class="max-w-4xl mx-auto px-8 text-center">
        <h2 class="font-['Space_Grotesk'] font-black text-white text-4xl lg:text-5xl mb-6 uppercase tracking-tight">
          Ready to Initiate?
        </h2>
        <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto font-['Inter']">
          Contact our infrastructure specialists to discuss your requirements. We provide detailed assessments and engineered solutions.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/contact/" class="btn-inverse group/btn">
            <span>Get a Free Quote</span>
            <span class="material-symbols-outlined transition-transform group-hover/btn:translate-x-1">arrow_forward</span>
          </a>
          <a href="tel:0800127665" class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest text-sm hover:bg-white/20 transition-colors border border-white/30">
            <span class="material-symbols-outlined">phone</span>
            <span>0800 1 BROOK</span>
          </a>
        </div>
      </div>
    </section>
    
  </main>
  
  <Footer />
</Layout>
