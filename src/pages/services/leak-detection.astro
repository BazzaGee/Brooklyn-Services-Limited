---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Gallery from '../../components/ui/Gallery.astro';

const title = "Leak Detection | Brooklyn Services - Detection Suite";
const description = "Professional leak detection in Christchurch using acoustic geophone and thermal imaging technology. Accurate leak location with minimal disruption. South Island-wide.";

const galleryImages = [
  { src: '/images/services/leak-detection/water-main-leak.jpg', alt: 'Locating water main for underground leak', caption: 'Water Main Location' },
  { src: '/images/services/leak-detection/leak-detect-1.jpg', alt: 'Leak detection in progress', caption: 'Acoustic Detection' },
  { src: '/images/services/leak-detection/leak-detect-2.jpg', alt: 'Leak detection work', caption: 'Leak Survey' },
  { src: '/images/services/leak-detection/leak-detect-3.jpg', alt: 'Leak detection site', caption: 'Site Detection' },
  { src: '/images/services/leak-detection/leak-detect-4.jpeg', alt: 'Underground leak detection', caption: 'Underground Leak' },
  { src: '/images/services/leak-detection/leak-detect-5.jpg', alt: 'Leak detection April 2025', caption: 'Recent Work' },
  { src: '/images/services/leak-detection/historical-leak-1.jpg', alt: 'Historical leak detection project', caption: 'Detection Work' },
  { src: '/images/services/leak-detection/historical-leak-2.jpg', alt: 'Leak detection equipment', caption: 'Equipment' },
];
---

<Layout title={title} description={description}>
  <div class="fixed inset-0 isometric-pattern pointer-events-none z-0"></div>
  
  <Header />
  
  <main class="relative z-10 space-y-0 px-4 pb-20 max-w-[1800px] mx-auto">
    
    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 min-h-[600px]">
      <div class="md:col-span-6 bg-[#1b1b1c] p-12 lg:p-20 flex flex-col justify-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[#CD5C5C]/20 to-transparent"></div>
        <div class="relative z-10">
          <div class="inline-block bg-[#CD5C5C] text-white px-4 py-1.5 text-xs font-black uppercase tracking-[0.25em] mb-6 skew-block shadow-md">
            <span class="skew-block-content">Detection Suite</span>
          </div>
          <h1 class="font-['Space_Grotesk'] font-black text-5xl lg:text-6xl text-white tracking-tighter leading-[0.9] uppercase mb-6">
            Leak<br/><span class="text-[#CD5C5C]">Detection</span>
          </h1>
          <p class="text-white/70 text-xl max-w-lg leading-relaxed font-light font-['Inter']">
            State-of-the-art ultra-sonic geophone acoustic technology and thermal imaging to pinpoint underground water leaks with minimal disruption. No unnecessary digging.
          </p>
          <p class="text-white/50 text-base mt-4 font-['Inter']">
            Christchurch-based, South Island-wide on request.
          </p>
          <div class="mt-10 flex gap-4">
            <a href="/contact/" class="btn-actuator">
              <span>Schedule Detection</span>
            </a>
          </div>
        </div>
      </div>
      <div class="md:col-span-6 bg-[#CD5C5C] p-12 lg:p-16 flex flex-col justify-center tetris-module-alt relative">
        <div class="grid grid-cols-2 gap-6">
          <div class="bg-white/10 p-8 skew-block group hover:bg-white/20 transition-colors">
            <div class="skew-block-content">
              <div class="font-['Space_Grotesk'] font-black text-5xl text-white mb-2">99.8%</div>
              <div class="text-white/80 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">Accuracy</div>
            </div>
          </div>
          <div class="bg-white p-8 skew-block group hover:scale-[1.02] transition-transform">
            <div class="skew-block-content">
              <div class="font-['Space_Grotesk'] font-black text-5xl text-[#CD5C5C] mb-2">ZERO</div>
              <div class="text-[#1b1b1c]/70 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">Excavation</div>
            </div>
          </div>
          <div class="bg-white/10 p-8 skew-block group hover:bg-white/20 transition-colors">
            <div class="skew-block-content">
              <div class="font-['Space_Grotesk'] font-black text-5xl text-white mb-2">15+</div>
              <div class="text-white/80 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">Yrs Experience</div>
            </div>
          </div>
          <div class="bg-white/10 p-8 skew-block group hover:bg-white/20 transition-colors">
            <div class="skew-block-content">
              <div class="font-['Space_Grotesk'] font-black text-5xl text-white mb-2">24/7</div>
              <div class="text-white/80 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">Response</div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <section class="grid grid-cols-1 md:grid-cols-2 gap-0 mt-8">
      <div class="bg-[#f6f3f2] p-12 lg:p-16 border-r border-[#CD5C5C]/10 group hover:bg-white transition-colors">
        <div class="flex items-center gap-6 mb-8">
          <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black">Method A</span>
        </div>
        <span class="material-symbols-outlined text-[#CD5C5C] text-6xl mb-6 block">hearing</span>
        <h2 class="font-['Space_Grotesk'] font-black text-3xl text-[#1b1b1c] uppercase mb-6">Geophone Acoustic Detection</h2>
        <p class="text-[#564241] text-lg font-['Inter'] leading-relaxed mb-6">
          Our state-of-the-art geophone acoustic leak detector uses ultra-sonic technology to pinpoint underground water leaks with surgical accuracy. No unnecessary digging, no property damage.
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Underground pipe leaks
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Pressurised system detection
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Minimal surface disruption
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Precise location marking
          </li>
        </ul>
      </div>
      
      <div class="bg-[#1b1b1c] p-12 lg:p-16 group">
        <div class="flex items-center gap-6 mb-8">
          <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black">Method B</span>
        </div>
        <span class="material-symbols-outlined text-[#CD5C5C] text-6xl mb-6 block">thermostat</span>
        <h2 class="font-['Space_Grotesk'] font-black text-3xl text-white uppercase mb-6">Thermal Imaging</h2>
        <p class="text-white/70 text-lg font-['Inter'] leading-relaxed mb-6">
          Infrared thermal cameras detect temperature variations caused by water leaks. 
          Hot or cold water escaping from pipes creates visible thermal signatures invisible to the naked eye.
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Slab and underfloor leaks
          </li>
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Hot water pipe detection
          </li>
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Moisture mapping
          </li>
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Non-invasive scanning
          </li>
        </ul>
      </div>
    </section>

    <section class="py-20 lg:py-28 bg-[#e5e2e1] mt-0">
      <div class="max-w-6xl mx-auto px-8">
        <div class="text-center mb-16">
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Benefits</span>
          <h2 class="font-['Space_Grotesk'] font-black text-4xl text-[#1b1b1c] uppercase mt-4 tracking-tight">
            Why Professional Detection?
          </h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-white p-8 group hover:shadow-lg transition-all">
            <div class="w-14 h-14 bg-[#CD5C5C]/10 mb-6 flex items-center justify-center skew-block group-hover:bg-[#CD5C5C] transition-colors">
              <span class="material-symbols-outlined text-3xl text-[#CD5C5C] group-hover:text-white skew-block-content transition-colors">savings</span>
            </div>
            <h3 class="font-['Space_Grotesk'] font-black text-lg text-[#1b1b1c] uppercase mb-3">Cost Reduction</h3>
            <p class="text-[#564241] text-sm font-['Inter']">Find leaks before major damage. Targeted repairs save thousands in unnecessary excavation.</p>
          </div>
          
          <div class="bg-white p-8 group hover:shadow-lg transition-all">
            <div class="w-14 h-14 bg-[#CD5C5C]/10 mb-6 flex items-center justify-center skew-block group-hover:bg-[#CD5C5C] transition-colors">
              <span class="material-symbols-outlined text-3xl text-[#CD5C5C] group-hover:text-white skew-block-content transition-colors">shield</span>
            </div>
            <h3 class="font-['Space_Grotesk'] font-black text-lg text-[#1b1b1c] uppercase mb-3">Property Protection</h3>
            <p class="text-[#564241] text-sm font-['Inter']">Prevent water damage, rot, mold, and foundation deterioration before they develop.</p>
          </div>
          
          <div class="bg-white p-8 group hover:shadow-lg transition-all">
            <div class="w-14 h-14 bg-[#CD5C5C]/10 mb-6 flex items-center justify-center skew-block group-hover:bg-[#CD5C5C] transition-colors">
              <span class="material-symbols-outlined text-3xl text-[#CD5C5C] group-hover:text-white skew-block-content transition-colors">speed</span>
            </div>
            <h3 class="font-['Space_Grotesk'] font-black text-lg text-[#1b1b1c] uppercase mb-3">Fast Results</h3>
            <p class="text-[#564241] text-sm font-['Inter']">Same-day service available. Pinpoint accuracy means faster repairs and less downtime.</p>
          </div>
          
          <div class="bg-white p-8 group hover:shadow-lg transition-all">
            <div class="w-14 h-14 bg-[#CD5C5C]/10 mb-6 flex items-center justify-center skew-block group-hover:bg-[#CD5C5C] transition-colors">
              <span class="material-symbols-outlined text-3xl text-[#CD5C5C] group-hover:text-white skew-block-content transition-colors">eco</span>
            </div>
            <h3 class="font-['Space_Grotesk'] font-black text-lg text-[#1b1b1c] uppercase mb-3">Water Conservation</h3>
            <p class="text-[#564241] text-sm font-['Inter']">Stop water waste and reduce environmental impact with prompt leak identification and repair.</p>
          </div>
        </div>
      </div>
    </section>
    
    <Gallery 
      images={galleryImages}
      title="Our Leak Detection Work"
      subtitle="Real leak detection projects — from residential properties to large-scale commercial sites across Christchurch and the South Island."
      columns={4}
    />
    
    <section class="py-20 lg:py-28 bg-[#CD5C5C] mt-0">
      <div class="max-w-4xl mx-auto px-8 text-center">
        <h2 class="font-['Space_Grotesk'] font-black text-white text-4xl lg:text-5xl mb-6 uppercase tracking-tight">
          Suspect a Leak?
        </h2>
        <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto font-['Inter']">
          Unexplained water bills, damp spots, or reduced pressure? Our detection specialists can locate the source without destructive investigation.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/contact/" class="btn-inverse group/btn">
            <span>Schedule Detection</span>
            <span class="material-symbols-outlined transition-transform group-hover/btn:translate-x-1">arrow_forward</span>
          </a>
          <a href="tel:0800127665" class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest text-sm hover:bg-white/20 transition-colors border border-white/30">
            <span class="material-symbols-outlined">phone</span>
            <span>0800 1 BROOK</span>
          </a>
        </div>
        <p class="text-white/60 text-sm mt-6 font-['Inter']">
          South Island-wide service available
        </p>
      </div>
    </section>
    
  </main>
  
  <Footer />
</Layout>
