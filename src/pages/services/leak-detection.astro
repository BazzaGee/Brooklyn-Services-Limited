---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Gallery from '../../components/ui/Gallery.astro';
import HorizontalScroll from '../../components/ui/HorizontalScroll.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import FAQ from '../../components/ui/FAQ.astro';

const title = "Leak Detection | Brooklyn Services - Detection Suite";
const description = "Professional leak detection in Christchurch using acoustic geophone and thermal imaging technology. Accurate leak location with minimal disruption. South Island-wide.";

const galleryImages = [
  { src: '/images/services/leak-detection/water-main-leak.jpg', alt: 'Locating water main for underground leak', caption: 'Water Main Location' },
  { src: '/images/services/leak-detection/leak-detect-1.jpg', alt: 'Leak detection in progress', caption: 'Acoustic Detection' },
  { src: '/images/services/leak-detection/leak-detect-2.jpg', alt: 'Leak detection work', caption: 'Leak Survey' },
  { src: '/images/services/leak-detection/leak-detect-3.jpg', alt: 'Leak detection site', caption: 'Site Detection' },
  { src: '/images/services/leak-detection/leak-detect-4.jpeg', alt: 'Underground leak detection', caption: 'Underground Leak' },
  { src: '/images/services/leak-detection/leak-detect-5.jpg', alt: 'Leak detection April 2025', caption: 'Recent Work' },
  { src: '/images/services/leak-detection/historical-leak-1.jpg', alt: 'Historical leak detection project', caption: 'Detection Work' },
  { src: '/images/services/leak-detection/historical-leak-2.jpg', alt: 'Leak detection equipment', caption: 'Equipment' },
];

const faqItems = [
  {
    question: "How do you detect underground water leaks without digging?",
    answer: "We use state-of-the-art geophone acoustic technology and thermal imaging to pinpoint underground water leaks with surgical accuracy. Our ultra-sonic leak detectors listen for the sound of water escaping from pipes, while thermal cameras detect temperature variations caused by leaks. This non-invasive approach means we can locate leaks without unnecessary excavation."
  },
  {
    question: "What are the signs of a hidden water leak in my Christchurch home?",
    answer: "Common signs include: unexplained increases in your water bill, damp spots on walls or floors, musty odors, reduced water pressure, the sound of running water when taps are off, and visible mold growth. If you notice any of these signs, contact us immediately for a professional leak detection assessment."
  },
  {
    question: "How much does leak detection cost in Christchurch?",
    answer: "Our leak detection pricing depends on the size and complexity of the property. We provide free initial consultations and transparent pricing before starting any work. The cost of professional leak detection is typically far less than the damage caused by undetected leaks, including water waste, structural damage, and mold remediation."
  },
  {
    question: "Do you offer leak detection services outside Christchurch?",
    answer: "Yes. While we're based in Christchurch, we offer leak detection services South Island-wide on request. Our acoustic and thermal imaging equipment is portable, allowing us to service properties across Canterbury and beyond. Contact us to discuss your specific location and requirements."
  },
  {
    question: "Can you detect leaks in hot water pipes?",
    answer: "Yes. Our thermal imaging technology is particularly effective for detecting hot water pipe leaks. The temperature difference between the hot water and surrounding materials creates a visible thermal signature that our cameras can detect. We can locate leaks in hot water cylinders, continuous flow systems, and underfloor heating pipes."
  },
  {
    question: "How long does a typical leak detection survey take?",
    answer: "Most residential leak detection surveys can be completed within 1-2 hours. Commercial properties and larger sites may require more time depending on the complexity. We aim to provide same-day service across Christchurch and Canterbury, with rapid response for emergency situations."
  }
];
---

<Layout title={title} description={description}>
  <div class="fixed inset-0 isometric-pattern pointer-events-none z-0"></div>
  
  <Header />
  
  <main class="relative z-10 space-y-0 px-4 pb-20 max-w-[1800px] mx-auto">
    
    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 min-h-[600px]">
      <div class="md:col-span-6 bg-[#1b1b1c] p-12 lg:p-20 flex flex-col justify-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[#CD5C5C]/20 to-transparent"></div>
        <div class="relative z-10">
          <div class="inline-block bg-[#CD5C5C] text-white px-4 py-1.5 text-xs font-black uppercase tracking-[0.25em] mb-6 skew-block shadow-md">
            <span class="skew-block-content">Detection Suite</span>
          </div>
          <h1 class="font-['Space_Grotesk'] font-black text-4xl md:text-5xl lg:text-6xl text-white tracking-tighter leading-[0.9] uppercase mb-6">
            Leak<br/><span class="text-[#CD5C5C]">Detection</span>
          </h1>
          <p class="text-white/70 text-xl max-w-lg leading-relaxed font-light font-['Inter']">
            State-of-the-art ultra-sonic geophone acoustic technology and thermal imaging to pinpoint underground water leaks with minimal disruption. No unnecessary digging.
          </p>
          <p class="text-white/50 text-base mt-4 font-['Inter']">
            Christchurch-based, South Island-wide on request.
          </p>
          <div class="mt-10 flex gap-4">
            <a href="/contact/" class="btn-actuator">
              <span>Schedule Detection</span>
            </a>
          </div>
        </div>
      </div>
      <div class="md:col-span-6 bg-[#CD5C5C] p-12 lg:p-16 flex flex-col justify-center tetris-module-alt relative">
        <div class="grid grid-cols-2 gap-6">
          <div class="bg-white/10 p-8 skew-block group hover:bg-white/20 transition-colors">
            <div class="skew-block-content">
              <div class="font-['Space_Grotesk'] font-black text-5xl text-white mb-2">99.8%</div>
              <div class="text-white/80 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">Accuracy</div>
            </div>
          </div>
          <div class="bg-white p-8 skew-block group hover:scale-[1.02] transition-transform">
            <div class="skew-block-content">
              <div class="font-['Space_Grotesk'] font-black text-5xl text-[#CD5C5C] mb-2">ZERO</div>
              <div class="text-[#1b1b1c]/70 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">Excavation</div>
            </div>
          </div>
          <div class="bg-white/10 p-8 skew-block group hover:bg-white/20 transition-colors">
            <div class="skew-block-content">
              <div class="font-['Space_Grotesk'] font-black text-5xl text-white mb-2">15+</div>
              <div class="text-white/80 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">Yrs Experience</div>
            </div>
          </div>
          <div class="bg-white/10 p-8 skew-block group hover:bg-white/20 transition-colors">
            <div class="skew-block-content">
              <div class="font-['Space_Grotesk'] font-black text-5xl text-white mb-2">24/7</div>
              <div class="text-white/80 text-xs uppercase tracking-widest font-['Space_Grotesk'] font-bold">Response</div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Breadcrumbs -->
    <section class="px-4 -mt-4">
      <div class="bg-[#1b1b1c] px-6 py-4">
        <Breadcrumbs items={[{ label: 'Services', href: '/services/' }, { label: 'Leak Detection' }]} />
      </div>
    </section>
    
    <section class="grid grid-cols-1 md:grid-cols-2 gap-0 mt-8">
      <div class="bg-[#f6f3f2] p-12 lg:p-16 border-r border-[#CD5C5C]/10 group hover:bg-white transition-colors">
        <div class="flex items-center gap-6 mb-8">
          <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black">Method A</span>
        </div>
        <span class="material-symbols-outlined text-[#CD5C5C] text-6xl mb-6 block">hearing</span>
        <h2 class="font-['Space_Grotesk'] font-black text-3xl text-[#1b1b1c] uppercase mb-6">Geophone Acoustic Detection</h2>
        <p class="text-[#564241] text-lg font-['Inter'] leading-relaxed mb-6">
          Our state-of-the-art geophone acoustic leak detector uses ultra-sonic technology to pinpoint underground water leaks with surgical accuracy. No unnecessary digging, no property damage.
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Underground pipe leaks
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Pressurised system detection
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Minimal surface disruption
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Precise location marking
          </li>
        </ul>
      </div>
      
      <div class="bg-[#1b1b1c] p-12 lg:p-16 group">
        <div class="flex items-center gap-6 mb-8">
          <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black">Method B</span>
        </div>
        <span class="material-symbols-outlined text-[#CD5C5C] text-6xl mb-6 block">thermostat</span>
        <h2 class="font-['Space_Grotesk'] font-black text-3xl text-white uppercase mb-6">Thermal Imaging</h2>
        <p class="text-white/70 text-lg font-['Inter'] leading-relaxed mb-6">
          Infrared thermal cameras detect temperature variations caused by water leaks. 
          Hot or cold water escaping from pipes creates visible thermal signatures invisible to the naked eye.
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Slab and underfloor leaks
          </li>
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Hot water pipe detection
          </li>
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Moisture mapping
          </li>
          <li class="flex items-center gap-3 text-white/70 font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Non-invasive scanning
          </li>
        </ul>
      </div>
    </section>

    <section class="bg-[#e5e2e1] mt-0">
      <div class="max-w-[1800px] mx-auto px-8 pt-20 lg:pt-28 pb-4">
        <div class="text-center mb-12">
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Benefits</span>
          <h2 class="font-['Space_Grotesk'] font-black text-4xl text-[#1b1b1c] uppercase mt-4 tracking-tight">
            Why Professional Detection?
          </h2>
        </div>
      </div>
      <HorizontalScroll bgColor="#e5e2e1">
        {[
          { icon: "savings", title: "Cost Reduction", desc: "Find leaks before major damage. Targeted repairs save thousands in unnecessary excavation.", color: "white" },
          { icon: "shield", title: "Property Protection", desc: "Prevent water damage, rot, mold, and foundation deterioration before they develop.", color: "#f6f3f2" },
          { icon: "speed", title: "Fast Results", desc: "Same-day service available. Pinpoint accuracy means faster repairs and less downtime.", color: "white" },
          { icon: "eco", title: "Water Conservation", desc: "Stop water waste and reduce environmental impact with prompt leak identification.", color: "#f6f3f2" },
          { icon: "plumbing", title: "Pipe Preservation", desc: "Non-invasive detection avoids damaging existing pipe work and surrounding structures.", color: "white" },
          { icon: "analytics", title: "Data Reporting", desc: "Comprehensive reports with leak locations, severity, and recommended remediation.", color: "#f6f3f2" },
          { icon: "location_on", title: "South Island Wide", desc: "Christchurch-based with availability across the entire South Island on request.", color: "white" },
          { icon: "trending_up", title: "Preventive Maintenance", desc: "Regular detection surveys catch developing issues before they become expensive failures.", color: "#f6f3f2" },
        ].map((item) => (
          <div class="group hover:shadow-lg transition-all" style={`min-width: 300px; max-width: 340px; background: ${item.color}; padding: 2rem;`}>
            <div class="w-14 h-14 bg-[#CD5C5C]/10 mb-6 flex items-center justify-center skew-block group-hover:bg-[#CD5C5C] transition-colors">
              <span class="material-symbols-outlined text-3xl text-[#CD5C5C] group-hover:text-white skew-block-content transition-colors">{item.icon}</span>
            </div>
            <h3 class="font-['Space_Grotesk'] font-black text-lg text-[#1b1b1c] uppercase mb-3">{item.title}</h3>
            <p class="text-[#564241] text-sm font-['Inter']">{item.desc}</p>
          </div>
        ))}
      </HorizontalScroll>
    </section>
    
    <Gallery 
      images={galleryImages}
      title="Our Leak Detection Work"
      subtitle="Real leak detection projects — from residential properties to large-scale commercial sites across Christchurch and the South Island."
      columns={4}
      horizontal={true}
    />
    
    <FAQ 
      items={faqItems}
      title="Leak Detection Questions"
      subtitle="Common questions from our Christchurch and Canterbury customers"
    />
    
    <!-- Related Services -->
    <section class="bg-[#1b1b1c]">
      <div class="max-w-[1800px] mx-auto px-8 pt-16 lg:pt-20 pb-8">
        <div class="flex items-center gap-6 mb-6">
          <div class="w-12 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Related Systems</span>
        </div>
        <h2 class="font-['Space_Grotesk'] font-black text-3xl lg:text-4xl text-white uppercase tracking-tight mb-8">
          You May Also Need
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 pb-8">
        <a href="/services/plumbing/" class="bg-[#252525] p-8 lg:p-12 group hover:bg-[#CD5C5C] transition-colors border-t border-[#CD5C5C]/10">
          <span class="material-symbols-outlined text-[#CD5C5C] text-5xl mb-4 block group-hover:text-white transition-colors">plumbing</span>
          <h3 class="font-['Space_Grotesk'] font-black text-xl text-white uppercase mb-2">Plumbing Dynamics</h3>
          <p class="text-white/60 text-sm group-hover:text-white/80 transition-colors font-['Inter']">Licensed plumbing for residential & commercial. Hot water, repairs & new builds.</p>
          <div class="mt-4 flex items-center gap-2 text-[#CD5C5C] group-hover:text-white transition-colors">
            <span class="font-['Space_Grotesk'] font-bold uppercase text-xs tracking-wider">Learn More</span>
            <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-1">arrow_forward</span>
          </div>
        </a>
        <a href="/services/drainage/" class="bg-[#252525] p-8 lg:p-12 group hover:bg-[#CD5C5C] transition-colors border-t border-[#CD5C5C]/10">
          <span class="material-symbols-outlined text-[#CD5C5C] text-5xl mb-4 block group-hover:text-white transition-colors">water_damage</span>
          <h3 class="font-['Space_Grotesk'] font-black text-xl text-white uppercase mb-2">Drainage Logistics</h3>
          <p class="text-white/60 text-sm group-hover:text-white/80 transition-colors font-['Inter']">Blocked drains, CCTV inspection, new installations & septic systems.</p>
          <div class="mt-4 flex items-center gap-2 text-[#CD5C5C] group-hover:text-white transition-colors">
            <span class="font-['Space_Grotesk'] font-bold uppercase text-xs tracking-wider">Learn More</span>
            <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-1">arrow_forward</span>
          </div>
        </a>
        <a href="/services/utility-locating/" class="bg-[#252525] p-8 lg:p-12 group hover:bg-[#CD5C5C] transition-colors border-t border-[#CD5C5C]/10">
          <span class="material-symbols-outlined text-[#CD5C5C] text-5xl mb-4 block group-hover:text-white transition-colors">radar</span>
          <h3 class="font-['Space_Grotesk'] font-black text-xl text-white uppercase mb-2">Utility Locating</h3>
          <p class="text-white/60 text-sm group-hover:text-white/80 transition-colors font-['Inter']">GPR scanning & cable detection before you dig. South Island-wide.</p>
          <div class="mt-4 flex items-center gap-2 text-[#CD5C5C] group-hover:text-white transition-colors">
            <span class="font-['Space_Grotesk'] font-bold uppercase text-xs tracking-wider">Learn More</span>
            <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-1">arrow_forward</span>
          </div>
        </a>
      </div>
    </section>
    
    <section class="py-20 lg:py-28 bg-[#CD5C5C] mt-0">
      <div class="max-w-4xl mx-auto px-8 text-center">
        <h2 class="font-['Space_Grotesk'] font-black text-white text-4xl lg:text-5xl mb-6 uppercase tracking-tight">
          Suspect a Leak?
        </h2>
        <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto font-['Inter']">
          Unexplained water bills, damp spots, or reduced pressure? Our detection specialists can locate the source without destructive investigation.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/contact/" class="btn-inverse group/btn">
            <span>Schedule Detection</span>
            <span class="material-symbols-outlined transition-transform group-hover/btn:translate-x-1">arrow_forward</span>
          </a>
          <a href="tel:0800127665" class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest text-sm hover:bg-white/20 transition-colors border border-white/30">
            <span class="material-symbols-outlined">phone</span>
            <span>0800 1 BROOK</span>
          </a>
        </div>
        <p class="text-white/60 text-sm mt-6 font-['Inter']">
          South Island-wide service available
        </p>
      </div>
    </section>
    
  </main>
  
  <Footer />
</Layout>
