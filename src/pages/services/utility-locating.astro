---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Gallery from '../../components/ui/Gallery.astro';
import HorizontalScroll from '../../components/ui/HorizontalScroll.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import FAQ from '../../components/ui/FAQ.astro';

const title = "Utility Locating | Brooklyn Services - System 03";
const description = "Professional utility locating services in Christchurch using GPR and electromagnetic technology. South Island-wide service. Call 0800 1 BROOK.";

const galleryImages = [
  { src: '/images/services/utility-locating/water-main-leak-locate.jpg', alt: 'Locating water main for underground leak', caption: 'Water Main Location' },
  { src: '/images/services/utility-locating/new-drain-locate-1.jpg', alt: 'Services located for new drain installation', caption: 'New Drain Services' },
  { src: '/images/services/utility-locating/new-drain-locate-2.jpg', alt: 'Services located for new drain', caption: 'Service Detection' },
  { src: '/images/services/utility-locating/historical-locate-1.jpg', alt: 'Utility locating project', caption: 'Project Work' },
  { src: '/images/services/utility-locating/alexandra-locate.jpg', alt: 'Locating services in Alexandra, Central Otago', caption: 'Central Otago' },
  { src: '/images/services/utility-locating/cctv-sonde-locate.jpg', alt: 'Locating a drain using CCTV camera and sonde', caption: 'CCTV & Sonde' },
];

const clients = [
  { name: 'Tonkin & Taylor', work: 'EQC Service locating in Christchurch' },
  { name: 'RDCL Geotech', work: 'Geophysics specialists — post-earthquake projects' },
  { name: 'Mainmark Ground Engineering', work: 'Building lifting projects' },
  { name: 'Downer Group NZ', work: 'Chorus UFB Rollout — Oamaru, Timaru, Ashburton; Kiwi Rail crossing upgrades' },
  { name: 'Ventia', work: 'Enable UFB Rollout — Christchurch and surrounding towns' },
  { name: 'Alpine Energy', work: 'Transpower Dark Fibre Network — Central Otago' },
  { name: 'EA Networks', work: 'Electricity and fibre upgrades — Ashburton/Mid Canterbury' },
  { name: 'Treetech', work: 'Arborist services' },
  { name: 'Apollo Projects', work: 'Fonterra Clandeboye utility locating' },
  { name: 'CCL Construction', work: 'New construction and subdivisions' },
  { name: "Barnsy's All Trade Services", work: 'Drainage and CCC water main upgrades' },
  { name: 'Fulton Hogan', work: 'Roading upgrades — Timaru and South Canterbury' },
  { name: 'Thompson Wentworth', work: 'Surveying and property maintenance' },
  { name: 'Everest Consultants', work: 'Underground service locating and mapping' },
];

const faqItems = [
  {
    question: "Why is utility locating important before excavation?",
    answer: "Utility strikes are costly, dangerous, and can cause service disruptions to entire neighborhoods. Before any excavation work — whether it's a new deck, subdivision, or road upgrade — professional utility locating identifies underground services to avoid damage. We use GPR, electromagnetic locating, and CCTV sonde tracking to provide accurate service maps."
  },
  {
    question: "What technology do you use for utility locating?",
    answer: "We use three main technologies: Ground Penetrating Radar (GPR) for non-metallic services like water mains and drains; electromagnetic locating for live cables and metallic pipes; and CCTV drain cameras with sonde for accurate drain location and depth measurement. This combination ensures comprehensive detection of all underground services."
  },
  {
    question: "Do you offer utility locating services outside Christchurch?",
    answer: "Yes. While we're based in Christchurch, we offer utility locating services South Island-wide on request. Our team has worked on projects across Canterbury, Central Otago, Timaru, Ashburton, and beyond. We're the preferred utility locating contractor for major infrastructure companies across the South Island."
  },
  {
    question: "Can you locate non-metallic underground services?",
    answer: "Yes. Our Ground Penetrating Radar (GPR) technology can detect non-metallic services including PVC water mains, drain pipes, ducts, and gas mains. This is particularly important in Christchurch where many post-earthquake repairs used non-metallic materials that traditional cable locators cannot detect."
  },
  {
    question: "How accurate is your utility locating service?",
    answer: "Our combination of GPR, electromagnetic locating, and CCTV sonde tracking provides highly accurate service location and depth measurement. We provide detailed mark-outs on the surface showing service paths and depths. Our accuracy has made us the preferred contractor for major infrastructure companies including Downer Group, Fulton Hogan, and Tonkin & Taylor."
  },
  {
    question: "Do you provide full street mark-outs for construction projects?",
    answer: "Yes. We provide full street mark-outs for construction sites, subdivisions, and roading projects across Canterbury. Our utility locators mark all detected services on the surface with paint and flags, indicating service type, path, and approximate depth. This ensures your excavation team can work safely and avoid damaging underground infrastructure."
  }
];
---

<Layout title={title} description={description}>
  <div class="fixed inset-0 isometric-pattern pointer-events-none z-0"></div>
  
  <Header />
  
  <main class="relative z-10 space-y-0 px-4 pb-20 max-w-[1800px] mx-auto">
    
    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 min-h-[600px]">
      <div class="md:col-span-7 bg-[#e5e2e1] p-12 lg:p-20 flex flex-col justify-center relative overflow-hidden">
        <div class="relative z-10">
          <div class="flex items-center gap-6 mb-8">
            <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
            <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">System 03</span>
          </div>
          <h1 class="font-['Space_Grotesk'] font-black text-5xl lg:text-6xl text-[#1b1b1c] tracking-tighter leading-[0.9] uppercase mb-6">
            Utility<br/><span class="text-[#CD5C5C]">Locating</span>
          </h1>
          <p class="text-[#564241] text-xl max-w-lg leading-relaxed font-light font-['Inter']">
            Sub-surface radar mapping (GPR), cable locating, and CCTV location for risk mitigation during heavy infrastructure development. Christchurch-based with South Island-wide availability.
          </p>
          <div class="mt-10 flex gap-4">
            <a href="/contact/" class="btn-actuator">
              <span>Request Survey</span>
            </a>
          </div>
        </div>
      </div>
      <div class="md:col-span-5 relative overflow-hidden bg-[#1b1b1c] tetris-module">
        <img 
          class="absolute inset-0 w-full h-full object-cover opacity-60 grayscale contrast-125"
          src="/images/services/utility-locating/new-drain-locate-1.jpg" 
          alt="Utility locating equipment in action"
        />
        <div class="absolute inset-0 bg-gradient-to-tl from-[#CD5C5C]/40 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8">
          <div class="bg-[#CD5C5C] inline-block px-4 py-2 skew-block">
            <span class="text-white font-['Space_Grotesk'] text-xs font-black uppercase tracking-wider skew-block-content">GPR Technology</span>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Breadcrumbs -->
    <section class="px-4 -mt-4">
      <div class="bg-[#e5e2e1] px-6 py-4">
        <Breadcrumbs items={[{ label: 'Services', href: '/services/' }, { label: 'Utility Locating' }]} />
      </div>
    </section>
    
    <section class="grid grid-cols-1 md:grid-cols-2 gap-0 mt-8">
      <div class="bg-[#1b1b1c] p-12 lg:p-16 group">
        <div class="flex items-center gap-6 mb-8">
          <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black">Technology A</span>
        </div>
        <span class="material-symbols-outlined text-[#CD5C5C] text-6xl mb-6 block">radar</span>
        <h2 class="font-['Space_Grotesk'] font-black text-3xl text-white uppercase mb-6">Ground Penetrating Radar</h2>
        <p class="text-white/70 text-lg font-['Inter'] leading-relaxed mb-6">
          Advanced GPR technology for non-metallic services — water mains, drains, ducts, and gas mains. Creates detailed sub-surface images without excavation.
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-white/60 font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Non-metallic pipe detection
          </li>
          <li class="flex items-center gap-3 text-white/60 font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Void and cavity identification
          </li>
          <li class="flex items-center gap-3 text-white/60 font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Concrete slab scanning
          </li>
          <li class="flex items-center gap-3 text-white/60 font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Depth estimation capabilities
          </li>
        </ul>
      </div>
      
      <div class="bg-[#f6f3f2] p-12 lg:p-16 group hover:bg-white transition-colors">
        <div class="flex items-center gap-6 mb-8">
          <div class="w-16 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-xs tracking-[0.3em] uppercase font-black">Technology B</span>
        </div>
        <span class="material-symbols-outlined text-[#CD5C5C] text-6xl mb-6 block">sensors</span>
        <h2 class="font-['Space_Grotesk'] font-black text-3xl text-[#1b1b1c] uppercase mb-6">Cable & CCTV Locating</h2>
        <p class="text-[#564241] text-lg font-['Inter'] leading-relaxed mb-6">
          Radio detection for power and telecommunications. CCTV drain cameras with sonde for accurate location and depth measurement of underground services.
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Live cable detection
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Metallic pipe tracing
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Full street mark outs
          </li>
          <li class="flex items-center gap-3 text-[#564241] font-['Inter']">
            <span class="w-2 h-2 bg-[#CD5C5C] skew-block"></span>
            Precise depth measurement
          </li>
        </ul>
      </div>
    </section>

    <section class="py-20 lg:py-28 bg-[#e5e2e1] mt-8">
      <div class="max-w-6xl mx-auto px-8">
        <div class="text-center mb-16">
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Trusted Partners</span>
          <h2 class="font-['Space_Grotesk'] font-black text-4xl text-[#1b1b1c] uppercase mt-4 tracking-tight">
            Client Portfolio
          </h2>
          <p class="text-[#564241] text-lg mt-4 max-w-2xl mx-auto font-['Inter']">
            We are the preferred utility locating contractor for major infrastructure companies across the South Island.
          </p>
        </div>
        
        <HorizontalScroll bgColor="#e5e2e1">
          {clients.map((client, index) => (
            <div class={`p-6 group transition-all ${index % 2 === 0 ? 'bg-white hover:shadow-lg' : 'bg-[#f6f3f2] hover:bg-white'}`} style="min-width: 320px; max-width: 380px;">
              <div class="flex items-center gap-4 mb-2">
                <div class="w-3 h-3 bg-[#CD5C5C] skew-block"></div>
                <h3 class="font-['Space_Grotesk'] font-black text-lg text-[#1b1b1c] uppercase tracking-tight">{client.name}</h3>
              </div>
              <p class="text-[#564241] text-sm font-['Inter'] pl-7">{client.work}</p>
            </div>
          ))}
        </HorizontalScroll>
      </div>
    </section>
    
    <Gallery 
      images={galleryImages}
      title="Our Utility Locating Work"
      subtitle="Utility detection projects across Christchurch, Canterbury, and the wider South Island."
      columns={3}
      horizontal={true}
    />
    
    <FAQ 
      items={faqItems}
      title="Utility Locating Questions"
      subtitle="Common questions from our Christchurch and Canterbury customers"
    />
    
    <!-- Related Services -->
    <section class="bg-[#f6f3f2]">
      <div class="max-w-[1800px] mx-auto px-8 pt-16 lg:pt-20 pb-8">
        <div class="flex items-center gap-6 mb-6">
          <div class="w-12 h-1.5 bg-[#CD5C5C] skew-block"></div>
          <span class="text-[#CD5C5C] font-['Space_Grotesk'] text-sm tracking-[0.3em] uppercase font-black">Related Systems</span>
        </div>
        <h2 class="font-['Space_Grotesk'] font-black text-3xl lg:text-4xl text-[#1b1b1c] uppercase tracking-tight mb-8">
          You May Also Need
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 pb-8">
        <a href="/services/plumbing/" class="bg-white p-8 lg:p-12 group hover:bg-[#CD5C5C] transition-colors">
          <span class="material-symbols-outlined text-[#CD5C5C] text-5xl mb-4 block group-hover:text-white transition-colors">plumbing</span>
          <h3 class="font-['Space_Grotesk'] font-black text-xl text-[#1b1b1c] uppercase mb-2 group-hover:text-white transition-colors">Plumbing Dynamics</h3>
          <p class="text-[#564241] text-sm group-hover:text-white/80 transition-colors font-['Inter']">Licensed plumbing for residential & commercial. Hot water, repairs & new builds.</p>
          <div class="mt-4 flex items-center gap-2 text-[#CD5C5C] group-hover:text-white transition-colors">
            <span class="font-['Space_Grotesk'] font-bold uppercase text-xs tracking-wider">Learn More</span>
            <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-1">arrow_forward</span>
          </div>
        </a>
        <a href="/services/drainage/" class="bg-white p-8 lg:p-12 group hover:bg-[#CD5C5C] transition-colors">
          <span class="material-symbols-outlined text-[#CD5C5C] text-5xl mb-4 block group-hover:text-white transition-colors">water_damage</span>
          <h3 class="font-['Space_Grotesk'] font-black text-xl text-[#1b1b1c] uppercase mb-2 group-hover:text-white transition-colors">Drainage Logistics</h3>
          <p class="text-[#564241] text-sm group-hover:text-white/80 transition-colors font-['Inter']">Blocked drains, CCTV inspection, new installations & septic systems.</p>
          <div class="mt-4 flex items-center gap-2 text-[#CD5C5C] group-hover:text-white transition-colors">
            <span class="font-['Space_Grotesk'] font-bold uppercase text-xs tracking-wider">Learn More</span>
            <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-1">arrow_forward</span>
          </div>
        </a>
        <a href="/services/leak-detection/" class="bg-white p-8 lg:p-12 group hover:bg-[#CD5C5C] transition-colors">
          <span class="material-symbols-outlined text-[#CD5C5C] text-5xl mb-4 block group-hover:text-white transition-colors">search</span>
          <h3 class="font-['Space_Grotesk'] font-black text-xl text-[#1b1b1c] uppercase mb-2 group-hover:text-white transition-colors">Leak Detection</h3>
          <p class="text-[#564241] text-sm group-hover:text-white/80 transition-colors font-['Inter']">Acoustic & thermal imaging to find hidden water leaks without digging.</p>
          <div class="mt-4 flex items-center gap-2 text-[#CD5C5C] group-hover:text-white transition-colors">
            <span class="font-['Space_Grotesk'] font-bold uppercase text-xs tracking-wider">Learn More</span>
            <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-1">arrow_forward</span>
          </div>
        </a>
      </div>
    </section>
    
    <section class="py-20 lg:py-28 bg-[#CD5C5C] mt-0">
      <div class="max-w-4xl mx-auto px-8 text-center">
        <h2 class="font-['Space_Grotesk'] font-black text-white text-4xl lg:text-5xl mb-6 uppercase tracking-tight">
          Before You Dig
        </h2>
        <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto font-['Inter']">
          Utility strikes are costly and dangerous. A professional locate survey is essential before any excavation work.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/contact/" class="btn-inverse group/btn">
            <span>Book a Survey</span>
            <span class="material-symbols-outlined transition-transform group-hover/btn:translate-x-1">arrow_forward</span>
          </a>
          <a href="tel:0800127665" class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 text-white font-['Space_Grotesk'] font-bold uppercase tracking-widest text-sm hover:bg-white/20 transition-colors border border-white/30">
            <span class="material-symbols-outlined">phone</span>
            <span>0800 1 BROOK</span>
          </a>
        </div>
        <p class="text-white/60 text-sm mt-6 font-['Inter']">
          South Island-wide service available
        </p>
      </div>
    </section>
    
  </main>
  
  <Footer />
</Layout>
